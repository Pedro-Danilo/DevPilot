{
  "name": "devpilot-local-web-ui",
  "version": "0.4.0-sprint-72",
  "private": true,
  "type": "module",
  "description": "DevPilot Local Web UI MVP dashboard, report/trace viewers, Approval Center and Settings UI.",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 5173",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1 --port 5173",
    "test": "node scripts/smoke-test.mjs"
  },
  "dependencies": {},
  "devDependencies": {
    "typescript": ">=5.4.0 <6.0.0",
    "vite": ">=5.0.0 <8.0.0"
  },
  "engines": {
    "node": ">=20"
  },
  "devpilot": {
    "sprint": "FUNC-SPRINT-72",
    "status": "implemented-initial",
    "apiOnly": true,
    "readOnly": false,
