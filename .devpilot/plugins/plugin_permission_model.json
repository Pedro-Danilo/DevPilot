  "permissions": [
    {
      "permission_id": "plugin.metadata.read",
      "description": "Read plugin manifest metadata only; this is not install, load or execute permission.",
      "effect": "allow",
      "risk_level": "low",
      "requires_approval": false,
      "side_effect": "read",
      "aliases": ["metadata"],
      "policy_rule_ids": ["PLUGIN_METADATA_READ_ALLOW", "PLUGIN_DRY_RUN_ONLY_ALLOW"],
      "notes": ["Allowed only for metadata-only validation and dry-run reporting."]
    },
    {
      "permission_id": "plugin.connector.read",
      "description": "Declare read-only connector metadata binding without invoking plugin code or connector writes.",
      "effect": "allow",
      "risk_level": "medium_high",
      "requires_approval": false,
      "side_effect": "report",
      "aliases": ["connector.read"],
      "policy_rule_ids": ["PLUGIN_CONNECTOR_BINDING_ALLOW", "CONNECTOR_CALL_READ_ONLY_ALLOW"],
      "notes": ["Allowed only while the referenced connector remains read-only, local and policy-bound."]
    },
    {
      "permission_id": "plugin.code.execute",
      "description": "Execute plugin-provided code. Explicitly denied until a future ADR authorizes a real sandbox with rollback.",
      "effect": "deny",
      "risk_level": "critical",
      "requires_approval": true,
      "blocked_until": "future-adr",
      "side_effect": "execute",
      "aliases": [],
      "policy_rule_ids": ["PLUGIN_EXECUTE_DENY"],
      "notes": ["NO-GO for POST-H-019; manifest validation is not execution permission."]
    },
    {
      "permission_id": "plugin.dynamic_import",
      "description": "Dynamically import plugin code with importlib or equivalent loaders.",
      "effect": "deny",
      "risk_level": "critical",
      "requires_approval": true,
      "blocked_until": "future-adr",
      "side_effect": "execute",
      "aliases": [],
      "policy_rule_ids": ["PLUGIN_EXECUTE_DENY"],
      "notes": ["NO-GO: dynamic import is not available in metadata-only mode."]
    },
    {
      "permission_id": "plugin.subprocess.run",
      "description": "Start subprocesses, shell commands or plugin-managed child processes.",
      "effect": "deny",
      "risk_level": "critical",
      "requires_approval": true,
      "blocked_until": "future-adr",
      "side_effect": "execute",
      "aliases": [],
