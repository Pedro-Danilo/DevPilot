      "notes": ["NO-GO: subprocess execution remains blocked."]
    },
    {
      "permission_id": "plugin.network.access",
      "description": "Allow plugin discovery, runtime behavior or dependency retrieval through network access.",
      "effect": "deny",
      "risk_level": "critical",
      "requires_approval": true,
      "blocked_until": "future-adr",
      "side_effect": "network",
      "aliases": [],
