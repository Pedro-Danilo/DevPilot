    {
      "permission_id": "plugin.filesystem.write",
      "description": "Write to workspace files, plugin directories or persistent state from plugin behavior.",
      "effect": "deny",
      "risk_level": "critical",
      "requires_approval": true,
      "blocked_until": "future-adr",
      "side_effect": "write",
