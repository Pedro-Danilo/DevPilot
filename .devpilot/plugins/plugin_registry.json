      "default_effect": "deny",
      "manifest_path": ".devpilot/plugins/plugin_registry.json#/plugins/local.docs.plugin",
      "entrypoint": "disabled://local.docs.plugin",
      "loading_mode": "metadata-only",
      "permissions": [
        {
          "permission_id": "metadata",
          "capability": "Inspect plugin metadata and policy bindings.",
          "description": "Return public plugin manifest metadata only.",
          "side_effect": "read",
          "allowed": true,
          "policy_rule_ids": [
            "PLUGIN_METADATA_READ_ALLOW",
            "PLUGIN_DRY_RUN_ONLY_ALLOW"
          ]
        },
        {
          "permission_id": "connector.read",
          "capability": "Use local.docs connector metadata in dry-run evidence flows.",
          "description": "Declare read-only connector integration without invoking arbitrary plugin code.",
          "side_effect": "report",
          "allowed": true,
          "policy_rule_ids": [
            "PLUGIN_CONNECTOR_BINDING_ALLOW",
            "CONNECTOR_CALL_READ_ONLY_ALLOW"
          ]
        }
      ],
      "policy_rule_ids": [
        "PLUGIN_METADATA_READ_ALLOW",
        "PLUGIN_DRY_RUN_ONLY_ALLOW",
        "PLUGIN_CONNECTOR_BINDING_ALLOW",
        "CONNECTOR_CALL_READ_ONLY_ALLOW",
        "SECRETS_RAW_DENY"
      ],
      "connectors": [
        "local.docs"
      ],
      "observability_required": true,
      "eval_required": true,
      "approval_required": false,
      "network_allowed": false,
      "external_api_allowed": false,
      "shell_allowed": false,
      "remote_execution_allowed": false,
      "execution_enabled": false
    },
