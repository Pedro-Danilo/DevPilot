schema_version: "2.0"
providers:
  - id: "mock"
    kind: "mock"
    enabled: true
    default_model: "mock-deterministic-v1"
    external_api: false
    requires_api_key: false
    estimated_cost_per_1k_tokens_usd: 0.0
    status: "implemented"
    notes:
      - "Default deterministic offline provider for tests and baseline CLI flows."
      - "No API key, network or external cost."
      - "FUNC-SPRINT-45 keeps mock mandatory so DevPilot remains reproducible without local model servers."
  - id: "ollama"
    kind: "local"
    enabled: false
    default_model: "qwen2.5:3b-instruct"
    endpoint: "http://localhost:11434"
    external_api: false
    requires_api_key: false
    estimated_cost_per_1k_tokens_usd: 0.0
    status: "planned"
    notes:
      - "Local optional provider planned for FUNC-SPRINT-46."
      - "Disabled by default; tests must not require an Ollama server."
      - "Endpoint must remain localhost-only unless a future ADR changes policy."
  - id: "lmstudio"
    kind: "local"
    enabled: false
    default_model: "local-model"
    endpoint: "http://localhost:1234"
    external_api: false
    requires_api_key: false
    estimated_cost_per_1k_tokens_usd: 0.0
    status: "planned"
    notes:
      - "Local OpenAI-compatible endpoint planned for FUNC-SPRINT-47."
      - "Disabled by default; tests must not require LM Studio."
      - "Only localhost base URLs are accepted by the provider contract."
  - id: "openai"
    kind: "api"
    enabled: false
    default_model: "gpt-placeholder"
    endpoint: "https://api.openai.com"
    external_api: true
    requires_api_key: true
    api_key_env: "OPENAI_API_KEY"
    estimated_cost_per_1k_tokens_usd: 0.01
    status: "disabled"
    notes:
      - "External API placeholder; blocked by CostGuard and PolicyEngine by default."
      - "Never store raw API keys in this file. Only environment variable names are allowed."
  - id: "gemini"
    kind: "api"
    enabled: false
    default_model: "gemini-placeholder"
    endpoint: "https://generativelanguage.googleapis.com"
    external_api: true
    requires_api_key: true
    api_key_env: "GEMINI_API_KEY"
    estimated_cost_per_1k_tokens_usd: 0.01
    status: "disabled"
    notes:
      - "External API placeholder; blocked by CostGuard and PolicyEngine by default."
      - "Never store raw API keys in this file. Only environment variable names are allowed."
