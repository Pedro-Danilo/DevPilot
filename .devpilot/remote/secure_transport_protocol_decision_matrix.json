  "decision_matrix": [
    {
      "protocol_id": "local-only-no-transport",
      "name": "Local-only without active transport",
      "current_decision": "selected_current",
      "rank": 1,
      "implementation_allowed_now": false,
      "network_required_if_implemented": false,
      "strengths": [
        "Preserves local-first posture",
        "No sockets, certificates or secrets",
        "Keeps remote execution disabled"
      ],
      "blockers_now": [
        "Does not provide remote capability by design",
        "Future enterprise transport remains unresolved"
      ],
      "required_future_controls": [
        "ADR de enablement posterior",
        "transport quality gate",
        "no-network invariant until enablement"
      ],
      "rejection_reason_now": "Not rejected; selected as current safe state."
    },
    {
      "protocol_id": "mtls-over-http2",
      "name": "mTLS over HTTP/2",
      "current_decision": "future_candidate_only",
      "rank": 2,
      "implementation_allowed_now": false,
      "network_required_if_implemented": true,
      "strengths": [
        "Mutual endpoint authentication",
        "Enterprise-compatible service identity",
        "Strong basis for certificate pinning and revocation"
      ],
      "blockers_now": [
        "No key/certificate lifecycle yet",
        "No trust root or CA policy",
        "No rotation/revocation design",
        "No network quality gate"
      ],
      "required_future_controls": [
        "key_certificate_lifecycle",
        "revocation_rotation",
        "certificate_pinning",
        "transport_observability",
        "kill_switch_and_rollback"
      ],
      "rejection_reason_now": "Rejected for current implementation because it would require active network, certificates and secrets before lifecycle controls exist."
    },
    {
      "protocol_id": "https-token-bound",
      "name": "HTTPS with token binding",
      "current_decision": "future_candidate_only",
      "rank": 3,
      "implementation_allowed_now": false,
      "network_required_if_implemented": true,
      "strengths": [
        "Operationally familiar HTTPS model",
        "Can support short-lived scoped credentials",
        "Compatible with gateway-style controls"
      ],
      "blockers_now": [
        "No token lifecycle",
        "No token theft/replay mitigation",
        "No DPoP/mTLS binding decision",
        "No secret storage model"
      ],
      "required_future_controls": [
        "token_binding",
        "short_lived_credentials",
        "replay_protection",
        "secret_handling_model",
        "audit_correlation"
      ],
      "rejection_reason_now": "Rejected for current implementation because token-bound HTTPS would introduce secrets and replay risk without lifecycle controls."
    },
    {
      "protocol_id": "ssh-restricted",
      "name": "Restricted SSH",
      "current_decision": "rejected_now",
      "rank": 4,
      "implementation_allowed_now": false,
      "network_required_if_implemented": true,
      "strengths": [
        "Mature transport primitive",
        "Can be constrained with forced commands",
        "Well understood operational tooling"
      ],
      "blockers_now": [
        "Shell semantics are too close to remote execution",
        "Key sprawl risk",
        "PolicyEngine and Approval binding are harder to guarantee",
        "Audit parity is weaker"
      ],
      "required_future_controls": [
        "no_shell_contract",
        "forced_command_only",
        "approval_bound_session",
        "rbac_command_allowlist",
        "transport_audit_parity"
      ],
      "rejection_reason_now": "Rejected now because SSH risks conflating secure transport with shell/remote execution and requires stronger isolation than currently available."
    }
