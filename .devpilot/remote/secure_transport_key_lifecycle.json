        "pinning_policy",
        "rotation_and_expiry"
      ]
    },
    {
      "class_id": "token-binding-secret",
      "name": "Token binding secret",
      "allowed_now": false,
      "storage_allowed_now": false,
      "raw_value_allowed": false,
      "redaction_required": true,
      "future_controls": [
        "short_lived_credentials",
        "replay_protection",
        "scope_binding"
      ]
    }
  ],
  "redaction_audit_requirements": [
    "Only references, fingerprints or hashes may appear in reports",
    "Raw private keys, tokens, CA secrets and certificate bodies remain forbidden",
    "Audit events must bind actor, role, approval_id and policy decision",
    "Revocation and rotation events must be traceable without exposing material",
    "Failure paths must be logged as metadata only"
  ],
  "storage_policy": {
    "raw_secret_storage_allowed": false,
    "repo_storage_allowed": false,
    "runtime_db_storage_allowed": false,
    "logs_raw_secret_allowed": false,
