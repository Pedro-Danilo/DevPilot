  "created_by": "POST-H-023-C",
  "updated": "2026-07-02",
  "status": "implemented-initial",
  "decision_status": "design-only",
  "lifecycle_status": "design-only-no-material",
  "transport_implemented": false,
  "network_allowed": false,
  "certificates_generated": false,
  "raw_secret_storage_allowed": false,
  "private_key_material_present": false,
  "requires_future_enablement_adr": true,
  "lifecycle_phases": [
    {
      "phase_id": "generation-design",
      "name": "Generation design",
      "design_goal": "Define future certificate/key generation prerequisites without generating material now.",
      "implementation_allowed_now": false,
      "material_generated_now": false,
      "required_controls": [
        "future_enablement_adr",
        "approved_ca_model",
        "entropy_source_policy",
        "operator_approval_binding"
      ],
      "audit_requirements": [
        "record generation request metadata",
        "record approval id",
        "never log generated private material"
      ],
      "failure_mode": "fail-closed if CA model, approval or entropy source is missing"
    },
    {
      "phase_id": "storage-design",
      "name": "Storage design",
      "design_goal": "Define future storage boundaries and forbid raw secret storage in source, logs and local DB.",
      "implementation_allowed_now": false,
      "material_generated_now": false,
      "required_controls": [
        "secret_handling_model",
        "encrypted_secret_store",
        "rbac_secret_read_boundary",
        "redaction_policy"
      ],
      "audit_requirements": [
        "record secret reference only",
        "record actor and role",
        "redact raw values in reports"
      ],
      "failure_mode": "fail-closed if raw material would be persisted"
    },
    {
      "phase_id": "distribution-design",
      "name": "Distribution design",
      "design_goal": "Define future credential distribution without network or worker provisioning now.",
      "implementation_allowed_now": false,
      "material_generated_now": false,
      "required_controls": [
        "secure_channel_after_enablement",
        "endpoint_identity_binding",
        "policy_engine_binding",
        "approval_scope_binding"
      ],
      "audit_requirements": [
        "record target identity",
        "record fingerprint reference",
        "record policy decision"
      ],
      "failure_mode": "fail-closed if target identity or policy binding cannot be verified"
    },
    {
      "phase_id": "rotation-design",
      "name": "Rotation design",
      "design_goal": "Require planned overlap, bounded validity and rollback for future key/cert rotation.",
      "implementation_allowed_now": false,
      "material_generated_now": false,
      "required_controls": [
        "bounded_validity",
        "overlap_window",
        "rollback_plan",
        "rotation_test_contract"
      ],
      "audit_requirements": [
        "record old and new fingerprint references",
        "record rotation window",
        "record rollback outcome"
      ],
      "failure_mode": "fail-closed if rotation cannot prove continuity and revocation readiness"
    },
    {
      "phase_id": "revocation-design",
      "name": "Revocation design",
      "design_goal": "Define future revocation and kill-switch behavior for compromised credentials.",
      "implementation_allowed_now": false,
      "material_generated_now": false,
      "required_controls": [
        "revocation_registry",
        "kill_switch",
        "incident_response_runbook",
        "negative_acceptance_tests"
      ],
      "audit_requirements": [
        "record revocation reason",
        "record actor approval",
        "record propagation status"
      ],
      "failure_mode": "fail-closed on stale, revoked or unverifiable credential state"
    }
  ],
  "credential_classes": [
    {
      "class_id": "transport-cert",
      "name": "Transport certificate",
      "allowed_now": false,
      "storage_allowed_now": false,
      "raw_value_allowed": false,
      "redaction_required": true,
      "future_controls": [
        "certificate_lifecycle",
        "pinning_policy",
        "revocation_rotation"
      ]
    },
    {
