{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://devpilot.local/schemas/ui_api_shell_report.schema.json",
  "title": "DevPilot UI/API Shell Report v1",
  "description": "POST-H-014-E local-first quality-gate report for the UI/API industrial shell, route registries, smoke test, documentation and no-go safety flags.",
  "type": "object",
  "required": [
    "schema_version",
    "schema_id",
    "report_id",
    "created_by",
    "status",
    "generated_at_utc",
    "summary",
    "checks",
    "safety",
    "findings",
    "notes"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {"const": "1.0"},
    "schema_id": {"const": "SCHEMA-DEVPL-UI-API-SHELL-REPORT-V1"},
    "report_id": {"type": "string", "minLength": 1},
    "created_by": {"const": "POST-H-014-E"},
    "status": {"enum": ["implemented-initial", "closed", "draft"]},
    "generated_at_utc": {"type": "string", "minLength": 1},
    "summary": {
      "type": "object",
      "required": [
        "created_by",
        "status",
        "preliminary",
        "quality_gate_subgate",
        "quality_gate_ready",
        "api_registry_ok",
        "ui_registry_ok",
        "ui_smoke_ok",
        "documentation_ok",
        "registries_synchronized",
        "api_routes_total",
        "ui_routes_total",
        "no_go_violations_total",
        "blocking_findings_total",
        "read_only",
        "dry_run",
        "network_used",
        "external_api_used",
        "mutations_performed",
        "source_mutations_performed",
        "remote_execution_enabled",
        "connector_write_enabled",
        "plugin_execution_enabled",
        "llm_judge_used",
        "reports_written",
        "report_schema_valid"
      ],
      "additionalProperties": true,
      "properties": {
        "created_by": {"const": "POST-H-014-E"},
        "status": {"enum": ["implemented-initial", "closed", "draft"]},
        "preliminary": {"type": "boolean"},
        "quality_gate_subgate": {"const": "ui-api-industrial-shell"},
        "quality_gate_ready": {"type": "boolean"},
        "api_registry_ok": {"type": "boolean"},
        "ui_registry_ok": {"type": "boolean"},
        "ui_smoke_ok": {"type": "boolean"},
        "documentation_ok": {"type": "boolean"},
        "registries_synchronized": {"type": "boolean"},
        "api_routes_total": {"type": "integer", "minimum": 1},
        "api_protected_routes_total": {"type": "integer", "minimum": 0},
        "ui_routes_total": {"type": "integer", "minimum": 1},
        "no_go_violations_total": {"type": "integer", "minimum": 0},
        "findings_total": {"type": "integer", "minimum": 0},
        "warnings_total": {"type": "integer", "minimum": 0},
        "blocking_findings_total": {"type": "integer", "minimum": 0},
        "read_only": {"type": "boolean"},
        "dry_run": {"type": "boolean"},
        "network_used": {"type": "boolean"},
        "external_api_used": {"type": "boolean"},
        "mutations_performed": {"type": "boolean"},
        "source_mutations_performed": {"type": "boolean"},
        "remote_execution_enabled": {"type": "boolean"},
        "connector_write_enabled": {"type": "boolean"},
        "plugin_execution_enabled": {"type": "boolean"},
        "llm_judge_used": {"type": "boolean"},
        "reports_written": {"type": "boolean"},
        "report_schema_valid": {"type": "boolean"}
      }
    },
    "checks": {"type": "object", "additionalProperties": true},
    "safety": {
      "type": "object",
      "required": [
        "local_first",
        "read_only",
        "dry_run",
        "network_used",
        "external_api_used",
        "remote_execution_enabled",
        "connector_write_enabled",
        "plugin_execution_enabled",
        "source_mutations_performed",
        "llm_judge_used"
      ],
      "additionalProperties": false,
      "properties": {
        "local_first": {"const": true},
        "read_only": {"const": true},
        "dry_run": {"const": true},
        "network_used": {"const": false},
        "external_api_used": {"const": false},
        "remote_execution_enabled": {"const": false},
        "connector_write_enabled": {"const": false},
        "plugin_execution_enabled": {"const": false},
        "source_mutations_performed": {"const": false},
        "llm_judge_used": {"const": false}
      }
    },
    "findings": {"type": "array", "items": {"type": "object"}},
    "notes": {"type": "array", "items": {"type": "string"}}
  }
}
