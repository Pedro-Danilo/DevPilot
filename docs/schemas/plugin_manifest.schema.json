{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://devpilot.local/schemas/SCHEMA-DEVPL-PLUGIN-MANIFEST-V1",
  "title": "DevPilot Plugin Manifest Registry v1",
  "description": "Structural contract for .devpilot/plugins/plugin_registry.json. POST-H-019-B hardens manifests against the plugin permission model while keeping plugin execution disabled.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "registry_id",
    "status",
    "created_by",
    "updated",
    "owner",
    "permission_model_path",
    "defaults",
    "security",
    "plugins"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "minLength": 1
    },
    "registry_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "approved",
        "draft"
      ]
    },
    "created_by": {
      "type": "string",
      "pattern": "^FUNC-SPRINT-[0-9]{2}$"
    },
    "updated": {
      "type": "string",
      "minLength": 1
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "defaults": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "plugin_default_effect",
        "require_manifest",
        "require_policy_rule_ids",
        "require_permissions",
        "require_observability",
        "require_eval",
        "deny_unregistered_plugins",
        "executable_loading_default",
        "permission_model_required",
        "unknown_permissions_effect",
        "critical_permissions_require_future_adr"
      ],
      "properties": {
        "plugin_default_effect": {
          "const": "deny"
        },
        "require_manifest": {
          "const": true
        },
        "require_policy_rule_ids": {
          "const": true
        },
        "require_permissions": {
          "const": true
        },
        "require_observability": {
          "const": true
        },
        "require_eval": {
          "const": true
        },
        "deny_unregistered_plugins": {
          "const": true
        },
        "executable_loading_default": {
          "const": false
        },
        "permission_model_required": {
          "const": true
        },
        "unknown_permissions_effect": {
          "const": "deny"
        },
        "critical_permissions_require_future_adr": {
          "const": true
        }
      }
    },
    "security": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "plugin_code_loaded",
        "arbitrary_code_execution_performed",
        "network_used",
        "external_api_used",
        "shell_used",
        "remote_execution_used",
        "secrets_allowed",
        "raw_outputs_allowed",
        "dynamic_import_allowed",
        "subprocess_allowed",
        "filesystem_write_allowed",
        "pip_install_allowed",
        "marketplace_enabled"
      ],
      "properties": {
        "plugin_code_loaded": {
          "const": false
        },
        "arbitrary_code_execution_performed": {
          "const": false
        },
        "network_used": {
          "const": false
        },
        "external_api_used": {
          "const": false
        },
        "shell_used": {
          "const": false
        },
        "remote_execution_used": {
          "const": false
        },
        "secrets_allowed": {
          "const": false
        },
        "raw_outputs_allowed": {
          "const": false
        },
        "dynamic_import_allowed": {
          "const": false
        },
        "subprocess_allowed": {
          "const": false
        },
        "filesystem_write_allowed": {
          "const": false
        },
        "pip_install_allowed": {
          "const": false
        },
        "marketplace_enabled": {
          "const": false
        }
      }
    },
    "plugins": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "plugin_id",
          "name",
          "version",
          "owner",
          "status",
          "description",
          "risk_level",
          "default_effect",
          "manifest_path",
          "entrypoint",
          "loading_mode",
          "permissions",
          "policy_rule_ids",
          "connectors",
          "observability_required",
          "eval_required",
          "approval_required",
          "network_allowed",
          "external_api_allowed",
          "shell_allowed",
          "remote_execution_allowed",
          "execution_enabled"
        ],
        "properties": {
          "plugin_id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9_.-]*$"
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "version": {
            "type": "string",
            "minLength": 1
          },
          "owner": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "disabled",
              "planned",
              "implemented-initial",
              "implemented",
              "experimental"
            ]
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "risk_level": {
            "type": "string",
            "enum": [
              "low",
              "medium",
              "medium_high",
              "high",
              "critical"
            ]
          },
          "default_effect": {
            "const": "deny"
          },
          "manifest_path": {
            "type": "string",
            "minLength": 1
          },
          "entrypoint": {
            "type": "string",
            "pattern": "^(disabled|metadata)://.+$"
          },
          "loading_mode": {
            "type": "string",
            "enum": [
              "metadata-only",
              "dry-run"
            ]
          },
          "permissions": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "permission_id",
                "capability",
                "description",
                "side_effect",
                "allowed",
                "policy_rule_ids"
              ],
              "properties": {
                "permission_id": {
                  "type": "string",
                  "pattern": "^(plugin\\.[a-z0-9][a-z0-9_.-]*|metadata|connector\\.read)$"
                },
                "capability": {
                  "type": "string",
                  "minLength": 1
                },
                "description": {
                  "type": "string",
                  "minLength": 1
                },
                "side_effect": {
                  "type": "string",
                  "enum": [
                    "none",
                    "read",
                    "report",
                    "simulation"
                  ]
                },
                "allowed": {
                  "const": true
                },
                "policy_rule_ids": {
                  "type": "array",
                  "minItems": 1,
                  "uniqueItems": true,
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              }
            }
          },
          "policy_rule_ids": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "connectors": {
            "type": "array",
            "uniqueItems": true,
            "items": {
              "type": "string",
              "pattern": "^[a-z0-9][a-z0-9_.-]*$"
            }
          },
          "observability_required": {
            "const": true
          },
          "eval_required": {
            "const": true
          },
          "approval_required": {
            "type": "boolean"
          },
          "network_allowed": {
            "const": false
          },
          "external_api_allowed": {
            "const": false
          },
          "shell_allowed": {
            "const": false
          },
          "remote_execution_allowed": {
            "const": false
          },
          "execution_enabled": {
            "const": false
          }
        }
      }
    },
    "permission_model_path": {
      "const": ".devpilot/plugins/plugin_permission_model.json"
    }
  },
  "x-devpilot-schema-id": "SCHEMA-DEVPL-PLUGIN-MANIFEST-V1",
  "x-devpilot-version": "1.1.0",
  "x-devpilot-sprint": "POST-H-019-B",
  "x-devpilot-status": "registered",
  "x-devpilot-preliminary": true,
  "x-devpilot-validation-enabled-sprint": "POST-H-019-B"
}
