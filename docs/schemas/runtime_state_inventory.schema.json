{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://devpilot.local/schemas/runtime_state_inventory.schema.json",
  "title": "DevPilot Runtime State Inventory v1",
  "description": "POST-H-008-B structural contract for read-only runtime-state inventory reports generated from runtime_state_policy.json.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "schema_id",
    "inventory_id",
    "generated_at_utc",
    "policy_id",
    "status",
    "created_by",
    "artifacts_total",
    "by_class",
    "violations",
    "artifacts",
    "summary",
    "safety"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "schema_id": {
      "const": "SCHEMA-DEVPL-RUNTIME-STATE-INVENTORY-V1"
    },
    "inventory_id": {
      "type": "string",
      "minLength": 1
    },
    "generated_at_utc": {
      "type": "string",
      "minLength": 10
    },
    "policy_id": {
      "const": "devpilot-runtime-state-policy"
    },
    "artifacts_total": {
      "type": "integer",
      "minimum": 0
    },
    "by_class": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/class_summary"
      }
    },
    "violations": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/violation"
      }
    },
    "summary": {
      "$ref": "#/$defs/summary"
    },
    "safety": {
      "$ref": "#/$defs/safety"
    },
    "created_by": {
      "const": "POST-H-008-B"
    },
    "status": {
      "enum": [
        "implemented-initial"
      ]
    },
    "policy_path": {
      "type": "string",
      "minLength": 1
    },
    "artifacts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/artifact"
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "class_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "class_id",
        "artifacts_total",
        "bytes_total",
        "versionable",
        "cleanup_allowed",
        "redaction_required"
      ],
      "properties": {
        "class_id": {
          "type": "string",
          "pattern": "^[a-z0-9_.-]+$"
        },
        "artifacts_total": {
          "type": "integer",
          "minimum": 0
        },
        "bytes_total": {
          "type": "integer",
          "minimum": 0
        },
        "versionable": {
          "type": "boolean"
        },
        "cleanup_allowed": {
          "type": "boolean"
        },
        "redaction_required": {
          "type": "boolean"
        }
      }
    },
    "violation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "violation_id",
        "path",
        "severity",
        "recommended_action"
      ],
      "properties": {
        "violation_id": {
          "type": "string",
          "pattern": "^[A-Z0-9_]+$"
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "severity": {
          "enum": [
            "info",
            "warn",
            "block"
          ]
        },
        "recommended_action": {
          "type": "string",
          "minLength": 1
        },
        "class_id": {
          "type": "string"
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "policy_loaded",
        "read_only",
        "blocking_violations_total",
        "warnings_total",
        "preliminary"
      ],
      "properties": {
        "policy_loaded": {
          "type": "boolean"
        },
        "read_only": {
          "const": true
        },
        "blocking_violations_total": {
          "type": "integer",
          "minimum": 0
        },
        "warnings_total": {
          "type": "integer",
          "minimum": 0
        },
        "preliminary": {
          "const": true
        },
        "created_by": {
          "const": "POST-H-008-B"
        },
        "status": {
          "enum": [
            "implemented-initial"
          ]
        },
        "artifacts_total": {
          "type": "integer",
          "minimum": 0
        },
        "runtime_artifacts_total": {
          "type": "integer",
          "minimum": 0
        },
        "source_of_truth_artifacts_total": {
          "type": "integer",
          "minimum": 0
        },
        "versioned_runtime_artifacts_total": {
          "type": "integer",
          "minimum": 0
        },
        "sensitive_runtime_artifacts_total": {
          "type": "integer",
          "minimum": 0
        },
        "classes_total": {
          "type": "integer",
          "minimum": 0
        },
        "classes_with_artifacts_total": {
          "type": "integer",
          "minimum": 0
        },
        "git_metadata_available": {
          "type": "boolean"
        },
        "git_tracked_paths_total": {
          "type": "integer",
          "minimum": 0
        },
        "clean_zip_must_exclude_total": {
          "type": "integer",
          "minimum": 0
        },
        "cleanup_execution_enabled": {
          "const": false
        },
        "export_execution_enabled": {
          "const": false
        },
        "redaction_execution_enabled": {
          "const": false
        },
        "network_used": {
          "const": false
        },
        "external_api_used": {
          "const": false
        },
        "mutations_performed": {
          "const": false
        },
        "destructive_cleanup_performed": {
          "const": false
        },
        "source_mutations_performed": {
          "const": false
        },
        "reports_written": {
          "type": "boolean"
        },
        "output_json": {
          "type": [
            "string",
            "null"
          ]
        },
        "output_markdown": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "safety": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mutations_performed",
        "network_used",
        "external_api_used",
        "destructive_cleanup_performed",
        "source_mutations_performed",
        "cleanup_execution_enabled",
        "export_execution_enabled",
        "remote_execution_enabled",
        "connector_write_enabled",
        "plugin_execution_enabled"
      ],
      "properties": {
        "mutations_performed": {
          "const": false
        },
        "network_used": {
          "const": false
        },
        "external_api_used": {
          "const": false
        },
        "destructive_cleanup_performed": {
          "const": false
        },
        "source_mutations_performed": {
          "const": false
        },
        "cleanup_execution_enabled": {
          "const": false
        },
        "export_execution_enabled": {
          "const": false
        },
        "remote_execution_enabled": {
          "const": false
        },
        "connector_write_enabled": {
          "const": false
        },
        "plugin_execution_enabled": {
          "const": false
        }
      }
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "class_id",
        "classification",
        "size_bytes",
        "source_of_truth",
        "versionable",
        "sensitive",
        "cleanup_allowed",
        "export_allowed",
        "redaction_required",
        "never_delete",
        "git_tracked",
        "matched_patterns",
        "detected_in_source_tree"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "class_id": {
          "type": "string",
          "pattern": "^[a-z0-9_.-]+$"
        },
        "classification": {
          "type": "string",
          "minLength": 1
        },
        "size_bytes": {
          "type": "integer",
          "minimum": 0
        },
        "source_of_truth": {
          "type": "boolean"
        },
        "versionable": {
          "type": "boolean"
        },
        "sensitive": {
          "type": "boolean"
        },
        "cleanup_allowed": {
          "type": "boolean"
        },
        "export_allowed": {
          "type": "boolean"
        },
        "redaction_required": {
          "type": "boolean"
        },
        "never_delete": {
          "type": "boolean"
        },
        "git_tracked": {
          "type": "boolean"
        },
        "matched_patterns": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "detected_in_source_tree": {
          "type": "boolean"
        }
      }
    }
  }
}
