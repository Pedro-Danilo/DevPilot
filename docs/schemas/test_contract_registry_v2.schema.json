{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://devpilot.local/schemas/SCHEMA-DEVPL-TEST-CONTRACT-REGISTRY-V2",
  "title": "DevPilot Test Contract Registry v2",
  "description": "Structural contract for POST-H-003 Test Contract Registry 2.0. It classifies test contracts by domain, criticality, risk, cost, execution profile, trigger/impact and explicit safety flags without breaking v1 compatibility.",
  "type": "object",
  "required": [
    "schema_version",
    "schema_id",
    "created_by",
    "status",
    "compatibility",
    "contracts"
  ],
  "properties": {
    "schema_version": {
      "const": "2.0"
    },
    "schema_id": {
      "const": "SCHEMA-DEVPL-TEST-CONTRACT-REGISTRY-V2"
    },
    "created_by": {
      "const": "POST-H-003-A"
    },
    "status": {
      "enum": [
        "draft",
        "implemented-initial",
        "approved"
      ]
    },
    "description": {
      "type": "string"
    },
    "generated_from": {
      "type": [
        "string",
        "null"
      ]
    },
    "compatibility": {
      "type": "object",
      "required": [
        "v1_compatible",
        "v1_registry_path",
        "v1_schema_id",
        "migration_required",
        "compatibility_mode"
      ],
      "properties": {
        "v1_compatible": {
          "const": true
        },
        "v1_registry_path": {
          "const": ".devpilot/testing/test_contract_registry.json"
        },
        "v1_schema_id": {
          "const": "SCHEMA-DEVPL-TEST-CONTRACT-REGISTRY-V1"
        },
        "v2_schema_path": {
          "const": "docs/schemas/test_contract_registry_v2.schema.json"
        },
        "migration_required": {
          "type": "boolean"
        },
        "compatibility_mode": {
          "enum": [
            "parallel-read",
            "migration-dry-run"
          ]
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "additionalProperties": true
    },
    "profiles": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/profile"
      },
      "uniqueItems": true
    },
    "contracts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/contract"
      }
    }
  },
  "additionalProperties": true,
  "$defs": {
    "domain": {
      "enum": [
        "agentic.runtime",
        "agentic.multiagent",
        "application.service",
        "documentation.governance",
        "documentation.historical",
        "enterprise.remote",
        "enterprise.reporting",
        "extensibility.plugins",
        "governance.compliance",
        "governance.miasi",
        "governance.policy",
        "governance.project_state",
        "governance.schemas",
        "governance.testing",
        "integration.connectors",
        "interface.cli",
        "knowledge.rag",
        "operations.audit",
        "operations.observability",
        "operations.workspace",
        "product.api",
        "product.ui",
        "quality.gate",
        "release",
        "security.approval",
        "security.guards",
        "security.rbac"
      ]
    },
    "criticality": {
      "enum": [
        "P0",
        "P1",
        "P2",
        "P3"
      ]
    },
    "risk_level": {
      "enum": [
        "critical",
        "high",
        "medium",
        "low"
      ]
    },
    "test_type": {
      "enum": [
        "unit",
        "integration",
        "contract",
        "ui-smoke",
        "security",
        "release",
        "documentation",
        "schema",
        "quality-gate"
      ]
    },
    "execution_profile": {
      "enum": [
        "always",
        "impact",
        "release",
        "manual",
        "nightly-local"
      ]
    },
    "cost_class": {
      "enum": [
        "low",
        "medium",
        "high"
      ]
    },
    "classification_status": {
      "enum": [
        "explicit",
        "inferred",
        "needs-review"
      ]
    },
    "profile": {
      "type": "object",
      "required": [
        "profile_id",
        "description",
        "criticalities",
        "execution_profiles",
        "network_allowed",
        "external_api_allowed"
      ],
      "properties": {
        "profile_id": {
          "enum": [
            "p0-critical",
            "security",
            "release",
            "impact",
            "docs-historical",
            "nightly-local"
          ]
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "criticalities": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/criticality"
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "execution_profiles": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/execution_profile"
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "network_allowed": {
          "type": "boolean"
        },
        "external_api_allowed": {
          "type": "boolean"
        }
      },
      "additionalProperties": true
    },
    "safety_exception": {
      "type": "object",
      "required": [
        "justification",
        "approved_by",
        "expires_at_utc"
      ],
      "properties": {
        "justification": {
          "type": "string",
          "minLength": 12
        },
        "approved_by": {
          "type": "string",
          "minLength": 2
        },
        "expires_at_utc": {
          "type": "string",
          "minLength": 10
        },
        "scope": {
          "type": "string"
        },
        "rollback_or_cleanup": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "contract": {
      "type": "object",
      "required": [
        "contract_id",
        "schema_version",
        "domain",
        "capability",
        "criticality",
        "risk_level",
        "test_type",
        "execution_profile",
        "cost_class",
        "expected_duration_seconds",
        "test_files",
        "watched_paths",
        "validates",
        "required_for_release",
        "required_for_security_gate",
        "network_allowed",
        "external_api_allowed",
        "mutations_allowed",
        "requires_human_approval",
        "owner",
        "recommended_commands",
        "classification_status"
      ],
      "properties": {
        "contract_id": {
          "type": "string",
          "pattern": "^[a-z0-9_.-]+$"
        },
        "schema_version": {
          "const": "2.0"
        },
        "source_contract_id": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^[a-z0-9_.-]+$"
        },
        "domain": {
          "$ref": "#/$defs/domain"
        },
        "capability": {
          "type": "string",
          "minLength": 1
        },
        "criticality": {
          "$ref": "#/$defs/criticality"
        },
        "risk_level": {
          "$ref": "#/$defs/risk_level"
        },
        "test_type": {
          "$ref": "#/$defs/test_type"
        },
        "execution_profile": {
          "$ref": "#/$defs/execution_profile"
        },
        "cost_class": {
          "$ref": "#/$defs/cost_class"
        },
        "expected_duration_seconds": {
          "type": "number",
          "minimum": 0
        },
        "test_files": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "watched_paths": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "validates": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1
        },
        "trigger_hints": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "impact_scope": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "required_for_release": {
          "type": "boolean"
        },
        "required_for_security_gate": {
          "type": "boolean"
        },
        "network_allowed": {
          "type": "boolean"
        },
        "external_api_allowed": {
          "type": "boolean"
        },
        "mutations_allowed": {
          "type": "boolean"
        },
        "source_mutations_allowed": {
          "type": "boolean"
        },
        "requires_human_approval": {
          "type": "boolean"
        },
        "safety_exception": {
          "$ref": "#/$defs/safety_exception"
        },
        "owner": {
          "type": "string",
          "minLength": 1
        },
        "recommended_commands": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1
        },
        "classification_status": {
          "$ref": "#/$defs/classification_status"
        },
        "classification_notes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "network_allowed": {
                "const": true
              }
            },
            "required": [
              "network_allowed"
            ]
          },
          "then": {
            "required": [
              "safety_exception"
            ],
            "properties": {
              "requires_human_approval": {
                "const": true
              },
              "execution_profile": {
                "enum": [
                  "manual",
                  "release"
                ]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "external_api_allowed": {
                "const": true
              }
            },
            "required": [
              "external_api_allowed"
            ]
          },
          "then": {
            "required": [
              "safety_exception"
            ],
            "properties": {
              "requires_human_approval": {
                "const": true
              },
              "execution_profile": {
                "enum": [
                  "manual",
                  "release"
                ]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "mutations_allowed": {
                "const": true
              }
            },
            "required": [
              "mutations_allowed"
            ]
          },
          "then": {
            "required": [
              "safety_exception"
            ],
            "properties": {
              "requires_human_approval": {
                "const": true
              },
              "execution_profile": {
                "enum": [
                  "manual",
                  "release"
                ]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "source_mutations_allowed": {
                "const": true
              }
            },
            "required": [
              "source_mutations_allowed"
            ]
          },
          "then": {
            "required": [
              "safety_exception"
            ],
            "properties": {
              "requires_human_approval": {
                "const": true
              },
              "execution_profile": {
                "enum": [
                  "manual",
                  "release"
                ]
              }
            }
          }
        }
      ],
      "additionalProperties": true
    }
  },
  "x-devpilot-schema-id": "SCHEMA-DEVPL-TEST-CONTRACT-REGISTRY-V2",
  "x-devpilot-sprint": "POST-H-003-A",
  "x-devpilot-status": "registered"
}
