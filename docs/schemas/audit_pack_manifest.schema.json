{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://devpilot.local/schemas/SCHEMA-DEVPL-AUDIT-PACK-MANIFEST-V1",
  "x-devpilot-schema-id": "SCHEMA-DEVPL-AUDIT-PACK-MANIFEST-V1",
  "title": "DevPilot Audit Pack Manifest v1",
  "version": "1.0.0",
  "contract": "AuditPackManifest",
  "description": "Structural contract for FUNC-SPRINT-96 local audit pack manifests with checksums and export-policy metadata.",
  "type": "object",
  "required": [
    "schema_version",
    "schema_id",
    "pack_id",
    "title",
    "status",
    "generated_at",
    "generated_by_actor",
    "sprint",
    "local_first",
    "cloud_export_used",
    "network_used",
    "external_api_used",
    "secrets_exported",
    "runtime_db_exported",
    "providers_local_exported",
    "entries_total",
    "entries",
    "checksums"
  ],
  "properties": {
    "schema_version": {"type": "string"},
    "schema_id": {"const": "SCHEMA-DEVPL-AUDIT-PACK-MANIFEST-V1"},
    "pack_id": {"type": "string", "pattern": "^devpilot-audit-pack-[0-9]{8}T[0-9]{6}Z-[0-9a-f]{8}$"},
    "title": {"type": "string"},
    "status": {"enum": ["implemented-initial", "verified", "draft"]},
    "generated_at": {"type": "string"},
    "generated_by_actor": {"type": "string", "minLength": 1},
    "sprint": {"const": "FUNC-SPRINT-96"},
    "local_first": {"const": true},
    "cloud_export_used": {"const": false},
    "network_used": {"const": false},
    "external_api_used": {"const": false},
    "secrets_exported": {"const": false},
    "runtime_db_exported": {"const": false},
    "providers_local_exported": {"const": false},
    "entries_total": {"type": "integer", "minimum": 1},
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["path", "size_bytes", "sha256", "kind", "source", "secret_scan_passed"],
        "properties": {
          "path": {"type": "string", "minLength": 1},
          "size_bytes": {"type": "integer", "minimum": 0},
          "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
          "kind": {"type": "string"},
          "source": {"type": "string"},
          "secret_scan_passed": {"const": true}
        },
        "additionalProperties": true
      }
    },
    "checksums": {
      "type": "object",
      "additionalProperties": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
    },
    "notes": {"type": "array", "items": {"type": "string"}}
  },
  "additionalProperties": true
}
