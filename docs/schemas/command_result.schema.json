{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://devpilot.local/schemas/SCHEMA-DEVPL-COMMAND-RESULT-V1",
  "title": "DevPilot CommandResult v1",
  "description": "Structural contract for normalized DevPilot CLI command results.",
  "type": "object",
  "required": [
    "command",
    "ok",
    "exit_code",
    "message",
    "data",
    "findings"
  ],
  "properties": {
    "command": {
      "type": "string",
      "minLength": 1
    },
    "ok": {
      "type": "boolean"
    },
    "exit_code": {
      "type": "integer",
      "enum": [
        0,
        1,
        2,
        3
      ]
    },
    "message": {
      "type": "string"
    },
    "data": {
      "type": "object"
    },
    "findings": {
      "type": "array",
      "items": {
        "$ref": "finding.schema.json"
      }
    }
  },
  "additionalProperties": true,
  "x-devpilot-schema-id": "SCHEMA-DEVPL-COMMAND-RESULT-V1",
  "x-devpilot-version": "1.0.0",
  "x-devpilot-sprint": "FUNC-SPRINT-21",
  "x-devpilot-status": "registered",
  "x-devpilot-preliminary": true,
  "x-devpilot-note": "Registered by FUNC-SPRINT-21 and validated locally by SchemaValidator from FUNC-SPRINT-22. Validation is structural and does not replace semantic gates.",
  "x-devpilot-validation-enabled-sprint": "FUNC-SPRINT-22"
}
