{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://devpilot.local/schemas/SCHEMA-DEVPL-PROJECT-STATE-V1",
  "title": "DevPilot Project Global State v1",
  "description": "Structural contract for .devpilot/project_state.json after POST-H-001 centralizes mutable global project state.",
  "type": "object",
  "required": [
    "schema_version",
    "schema_id",
    "current_phase",
    "phase_h_status",
    "industrial_baseline_ready",
    "maturity_level",
    "last_completed_sprint",
    "last_functional_sprint",
    "next_sprint",
    "source_repo",
    "global_state_owner",
    "mutable_global_state_fields"
  ],
  "properties": {
    "schema_version": {"type": "string"},
    "schema_id": {"const": "SCHEMA-DEVPL-PROJECT-STATE-V1"},
    "current_phase": {"type": "string", "minLength": 1},
    "phase_h_status": {"enum": ["closed_implemented_initial", "open", "planned"]},
    "industrial_baseline_ready": {"type": "boolean"},
    "maturity_level": {"type": "string", "minLength": 1},
    "last_completed_sprint": {"type": "string", "pattern": "^(FUNC-SPRINT-[0-9]{2}|POST-H-[0-9]{3})$"},
    "last_functional_sprint": {"type": "string", "pattern": "^FUNC-SPRINT-[0-9]{2}$"},
    "next_sprint": {"type": "string", "pattern": "^(FUNC-SPRINT-[0-9]{2}|POST-H-[0-9]{3})$"},
    "source_repo": {"type": "string", "minLength": 1},
    "current_repo": {"type": "string"},
    "global_state_owner": {"type": "string", "minLength": 1},
    "mutable_global_state_fields": {"type": "array", "items": {"type": "string"}, "minItems": 1, "uniqueItems": true},
    "notes": {"type": "array", "items": {"type": "string"}}
  },
  "additionalProperties": true,
  "x-devpilot-schema-id": "SCHEMA-DEVPL-PROJECT-STATE-V1",
  "x-devpilot-sprint": "POST-H-001",
  "x-devpilot-status": "registered"
}
