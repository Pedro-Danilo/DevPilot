{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://devpilot.local/schemas/SCHEMA-DEVPL-MULTIAGENT-WORKFLOW-V1",
  "title": "DevPilot MultiAgent Workflow v1",
  "description": "Structural contract for governed local multiagent workflow definitions under .devpilot/workflows. Sprint 91 supports dry-run/report-only SDLC workflows only.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "workflow_id",
    "title",
    "status",
    "created_by",
    "updated",
    "owner",
    "mode",
    "dry_run_required",
    "report_only",
    "autonomy_open",
    "max_steps",
    "default_target",
    "policy_rule_ids",
    "safety",
    "steps",
    "outputs",
    "evals"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "workflow_id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "approved",
        "draft",
        "disabled"
      ]
    },
    "created_by": {
      "const": "FUNC-SPRINT-91"
    },
    "updated": {
      "type": "string",
      "minLength": 1
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "mode": {
      "const": "sequential-governed"
    },
    "dry_run_required": {
      "const": true
    },
    "report_only": {
      "const": true
    },
    "autonomy_open": {
      "const": false
    },
    "max_steps": {
      "type": "integer",
      "minimum": 1,
      "maximum": 10
    },
    "default_target": {
      "type": "string",
      "minLength": 1
    },
    "policy_rule_ids": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "safety": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mutations_allowed",
        "destructive_actions_allowed",
        "network_allowed",
        "external_api_allowed",
        "shell_allowed",
        "remote_execution_allowed",
        "secrets_allowed",
        "raw_prompt_storage_allowed"
      ],
      "properties": {
        "mutations_allowed": {
          "const": false
        },
        "destructive_actions_allowed": {
          "const": false
        },
        "network_allowed": {
          "const": false
        },
        "external_api_allowed": {
          "const": false
        },
        "shell_allowed": {
          "const": false
        },
        "remote_execution_allowed": {
          "const": false
        },
        "secrets_allowed": {
          "const": false
        },
        "raw_prompt_storage_allowed": {
          "const": false
        }
      }
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "maxItems": 10,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "step_id",
          "sequence",
          "agent_id",
          "reason",
          "expected_output",
          "required_trace",
          "risk_categories"
        ],
        "properties": {
          "step_id": {
            "type": "string",
            "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
          },
          "sequence": {
            "type": "integer",
            "minimum": 1,
            "maximum": 10
          },
          "agent_id": {
            "type": "string",
            "minLength": 1
          },
          "reason": {
            "type": "string",
            "minLength": 10
          },
          "expected_output": {
            "type": "string",
            "minLength": 1
          },
          "required_trace": {
            "const": true
          },
          "risk_categories": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "target": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "outputs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "report_id",
        "format",
        "consolidates",
        "write_path"
      ],
      "properties": {
        "report_id": {
          "type": "string",
          "pattern": "^[a-z0-9_]+$"
        },
        "format": {
          "const": "json+markdown"
        },
        "consolidates": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "write_path": {
          "type": "string",
          "pattern": "^outputs/reports/[a-z0-9_]+\\.\\*$"
        }
      }
    },
    "evals": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "fixture_path",
        "required"
      ],
      "properties": {
        "fixture_path": {
          "type": "string",
          "pattern": "^evals/fixtures/[A-Za-z0-9_./-]+\\.json$"
        },
        "required": {
          "const": true
        }
      }
    }
  }
}
