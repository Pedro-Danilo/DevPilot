{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://devpilot.local/schemas/application_operation_catalog.schema.json",
  "title": "DevPilot Application Operation Catalog v1",
  "description": "Declarative POST-H-007-B catalog of ApplicationService operations, interface mappings, safety metadata and test coverage.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "schema_id",
    "catalog_id",
    "created_by",
    "status",
    "generated_at_utc",
    "source_report_id",
    "required_initial_domains",
    "required_initial_domains_missing",
    "domains",
    "operations",
    "summary",
    "safety",
    "notes"
  ],
  "properties": {
    "schema_version": {"const": "1.0"},
    "schema_id": {"const": "SCHEMA-DEVPL-APPLICATION-OPERATION-CATALOG-V1"},
    "catalog_id": {"const": "devpilot-application-operation-catalog"},
    "created_by": {"const": "POST-H-007-B"},
    "status": {"enum": ["implemented-initial", "approved", "draft"]},
    "generated_at_utc": {"type": "string", "minLength": 10},
    "source_report_id": {"type": "string", "minLength": 1},
    "required_initial_domains": {
      "type": "array",
      "minItems": 10,
      "items": {"type": "string", "minLength": 1},
      "uniqueItems": true
    },
    "required_initial_domains_missing": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "uniqueItems": true
    },
    "domains": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1},
      "uniqueItems": true
    },
    "operations": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/operation"}
    },
    "summary": {"$ref": "#/$defs/summary"},
    "safety": {"$ref": "#/$defs/safety"},
    "notes": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    }
  },
  "$defs": {
    "operation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "operation_id",
        "domain",
        "service",
        "method",
        "request_contract",
        "response_contract",
        "cli_commands",
        "api_routes",
        "ui_surfaces",
        "exposed_to",
        "policy_required",
        "dry_run_default",
        "writes_files",
        "risk_level",
        "side_effects",
        "test_contract_ids",
        "test_coverage",
        "source",
        "status",
        "preliminary",
        "direct_core_bypass",
        "notes"
      ],
      "properties": {
        "operation_id": {"type": "string", "pattern": "^[a-z0-9_.-]+$"},
        "domain": {"type": "string", "minLength": 1},
        "service": {"type": "string", "minLength": 1},
        "method": {"type": "string", "minLength": 1},
        "request_contract": {"const": "ApplicationRequest"},
        "response_contract": {"const": "ApplicationResponse"},
        "cli_commands": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
        "api_routes": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
        "ui_surfaces": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
        "exposed_to": {
          "type": "array",
          "minItems": 1,
          "items": {"enum": ["cli", "api", "ui", "automation", "internal"]},
          "uniqueItems": true
        },
        "policy_required": {"type": "boolean"},
        "dry_run_default": {"type": "boolean"},
        "writes_files": {"type": "boolean"},
        "risk_level": {"enum": ["low", "medium", "high", "critical"]},
        "side_effects": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
        "test_contract_ids": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
        "test_coverage": {
          "type": "object",
          "additionalProperties": false,
          "required": ["covered", "coverage_source", "recommended_command"],
          "properties": {
            "covered": {"const": true},
            "coverage_source": {"type": "string", "minLength": 1},
            "recommended_command": {"type": "string", "minLength": 1}
          }
        },
        "source": {"type": "string", "minLength": 1},
        "status": {"enum": ["declared-initial", "approved", "draft"]},
        "preliminary": {"type": "boolean"},
        "direct_core_bypass": {"type": "boolean"},
        "notes": {"type": "array", "items": {"type": "string"}}
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "catalog_id",
        "schema_version",
        "schema_id",
        "created_by",
        "status",
        "generated_at_utc",
        "source_report_id",
        "operations_total",
        "domains_total",
        "required_initial_domains_total",
        "required_initial_domains_covered_total",
        "cli_bound_total",
        "api_bound_total",
        "ui_bound_total",
        "policy_required_total",
        "writes_files_total",
        "high_or_critical_total",
        "operations_with_test_contracts_total",
        "operations_without_test_contracts_total",
        "direct_core_bypass_total",
        "read_only",
        "dry_run",
        "network_used",
        "external_api_used",
        "mutations_performed",
        "source_mutations_performed",
        "remote_execution_enabled",
        "connector_write_enabled",
        "plugin_execution_enabled",
        "runtime_routes_added",
        "runtime_behavior_changed",
        "preliminary"
      ],
      "properties": {
        "catalog_id": {"const": "devpilot-application-operation-catalog"},
        "schema_version": {"const": "1.0"},
        "schema_id": {"const": "SCHEMA-DEVPL-APPLICATION-OPERATION-CATALOG-V1"},
        "created_by": {"const": "POST-H-007-B"},
        "status": {"type": "string"},
        "generated_at_utc": {"type": "string"},
        "source_report_id": {"type": "string"},
        "operations_total": {"type": "integer", "minimum": 1},
        "domains_total": {"type": "integer", "minimum": 1},
        "required_initial_domains_total": {"const": 10},
        "required_initial_domains_covered_total": {"type": "integer", "minimum": 0},
        "cli_bound_total": {"type": "integer", "minimum": 0},
        "api_bound_total": {"type": "integer", "minimum": 0},
        "ui_bound_total": {"type": "integer", "minimum": 0},
        "policy_required_total": {"type": "integer", "minimum": 0},
        "writes_files_total": {"type": "integer", "minimum": 0},
        "high_or_critical_total": {"type": "integer", "minimum": 0},
        "operations_with_test_contracts_total": {"type": "integer", "minimum": 1},
        "operations_without_test_contracts_total": {"const": 0},
        "direct_core_bypass_total": {"type": "integer", "minimum": 0},
        "reports_written": {"type": "boolean"},
        "output_json": {"type": ["string", "null"]},
        "output_markdown": {"type": ["string", "null"]},
        "read_only": {"const": true},
        "dry_run": {"const": true},
        "network_used": {"const": false},
        "external_api_used": {"const": false},
        "mutations_performed": {"const": false},
        "source_mutations_performed": {"const": false},
        "remote_execution_enabled": {"const": false},
        "connector_write_enabled": {"const": false},
        "plugin_execution_enabled": {"const": false},
        "runtime_routes_added": {"const": false},
        "runtime_behavior_changed": {"const": false},
        "preliminary": {"type": "boolean"}
      }
    },
    "safety": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "read_only",
        "dry_run",
        "network_used",
        "external_api_used",
        "mutations_performed",
        "source_mutations_performed",
        "remote_execution_enabled",
        "connector_write_enabled",
        "plugin_execution_enabled",
        "runtime_routes_added",
        "runtime_behavior_changed"
      ],
      "properties": {
        "read_only": {"const": true},
        "dry_run": {"const": true},
        "network_used": {"const": false},
        "external_api_used": {"const": false},
        "mutations_performed": {"const": false},
        "source_mutations_performed": {"const": false},
        "remote_execution_enabled": {"const": false},
        "connector_write_enabled": {"const": false},
        "plugin_execution_enabled": {"const": false},
        "runtime_routes_added": {"const": false},
        "runtime_behavior_changed": {"const": false}
      }
    }
  }
}
