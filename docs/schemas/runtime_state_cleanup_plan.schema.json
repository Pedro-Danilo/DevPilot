{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://devpilot.local/schemas/runtime_state_cleanup_plan.schema.json",
  "title": "DevPilot Runtime State Cleanup Plan v1",
  "description": "POST-H-008-C structural contract for dry-run-first runtime-state cleanup plans generated from RuntimeStateInventory and RuntimeStatePolicy.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "schema_id",
    "cleanup_plan_id",
    "created_by",
    "status",
    "generated_at_utc",
    "policy_id",
    "execution_mode",
    "groups",
    "summary",
    "safety"
  ],
  "properties": {
    "schema_version": {"const": "1.0"},
    "schema_id": {"const": "SCHEMA-DEVPL-RUNTIME-STATE-CLEANUP-PLAN-V1"},
    "cleanup_plan_id": {"const": "devpilot-runtime-state-cleanup-plan"},
    "created_by": {"const": "POST-H-008-C"},
    "status": {"enum": ["implemented-initial"]},
    "generated_at_utc": {"type": "string", "minLength": 10},
    "policy_id": {"const": "devpilot-runtime-state-policy"},
    "policy_path": {"type": "string"},
    "inventory_id": {"type": ["string", "null"]},
    "execution_mode": {"enum": ["dry-run", "execute"]},
    "groups": {"$ref": "#/$defs/groups"},
    "summary": {"$ref": "#/$defs/summary"},
    "safety": {"$ref": "#/$defs/safety"},
    "notes": {"type": "array", "items": {"type": "string"}}
  },
  "$defs": {
    "groups": {
      "type": "object",
      "additionalProperties": false,
      "required": ["safe_cleanup", "requires_approval", "never_delete", "retained"],
      "properties": {
        "safe_cleanup": {"type": "array", "items": {"$ref": "#/$defs/plan_item"}},
        "requires_approval": {"type": "array", "items": {"$ref": "#/$defs/plan_item"}},
        "never_delete": {"type": "array", "items": {"$ref": "#/$defs/plan_item"}},
        "retained": {"type": "array", "items": {"$ref": "#/$defs/plan_item"}}
      }
    },
    "plan_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "class_id",
        "classification",
        "decision",
        "reason",
        "size_bytes",
        "age_days",
        "retention_days",
        "source_of_truth",
        "versionable",
        "sensitive",
        "cleanup_allowed",
        "never_delete",
        "git_tracked",
        "execute_allowed",
        "execution_status"
      ],
      "properties": {
        "path": {"type": "string", "minLength": 1},
        "class_id": {"type": "string", "minLength": 1},
        "classification": {"type": "string", "minLength": 1},
        "decision": {"enum": ["safe-cleanup", "requires-approval", "never-delete", "retained"]},
        "reason": {"type": "string", "minLength": 1},
        "size_bytes": {"type": "integer", "minimum": 0},
        "age_days": {"type": "integer", "minimum": 0},
        "retention_days": {"type": "integer", "minimum": 0},
        "source_of_truth": {"type": "boolean"},
        "versionable": {"type": "boolean"},
        "sensitive": {"type": "boolean"},
        "cleanup_allowed": {"type": "boolean"},
        "never_delete": {"type": "boolean"},
        "git_tracked": {"type": "boolean"},
        "execute_allowed": {"type": "boolean"},
        "execution_status": {"enum": ["planned", "not-applicable", "deleted", "missing", "error"]}
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "created_by",
        "status",
        "dry_run",
        "execute_requested",
        "execute_allowed",
        "explicit_confirmation_required",
        "explicit_confirmation_provided",
        "source_of_truth_never_delete",
        "safe_cleanup_total",
        "requires_approval_total",
        "never_delete_total",
        "retained_total",
        "items_total",
        "cleanup_execution_enabled",
        "export_execution_enabled",
        "network_used",
        "external_api_used",
        "mutations_performed",
        "destructive_cleanup_performed",
        "source_mutations_performed"
      ],
      "properties": {
        "created_by": {"const": "POST-H-008-C"},
        "status": {"const": "implemented-initial"},
        "preliminary": {"type": "boolean"},
        "dry_run": {"type": "boolean"},
        "execute_requested": {"type": "boolean"},
        "execute_allowed": {"type": "boolean"},
        "explicit_confirmation_required": {"type": "boolean"},
        "explicit_confirmation_provided": {"type": "boolean"},
        "execution_blocked": {"type": "boolean"},
        "read_only_plan": {"type": "boolean"},
        "source_of_truth_never_delete": {"const": true},
        "safe_cleanup_total": {"type": "integer", "minimum": 0},
        "requires_approval_total": {"type": "integer", "minimum": 0},
        "never_delete_total": {"type": "integer", "minimum": 0},
        "retained_total": {"type": "integer", "minimum": 0},
        "items_total": {"type": "integer", "minimum": 0},
        "eligible_for_automatic_cleanup_total": {"type": "integer", "minimum": 0},
        "requires_human_approval_total": {"type": "integer", "minimum": 0},
        "deletions_planned_total": {"type": "integer", "minimum": 0},
        "deletions_performed_total": {"type": "integer", "minimum": 0},
        "deletion_errors_total": {"type": "integer", "minimum": 0},
        "cleanup_execution_enabled": {"type": "boolean"},
        "export_execution_enabled": {"const": false},
        "redaction_execution_enabled": {"const": false},
        "network_used": {"const": false},
        "external_api_used": {"const": false},
        "mutations_performed": {"type": "boolean"},
        "destructive_cleanup_performed": {"type": "boolean"},
        "source_mutations_performed": {"const": false},
        "reports_written": {"type": "boolean"},
        "output_json": {"type": ["string", "null"]},
        "output_markdown": {"type": ["string", "null"]}
      }
    },
    "safety": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "dry_run_default",
        "execute_requires_confirmation",
        "only_safe_cleanup_execute_allowed",
        "source_of_truth_never_delete",
        "forbidden_source_prefixes",
        "mutations_performed",
        "network_used",
        "external_api_used",
        "destructive_cleanup_performed",
        "source_mutations_performed",
        "cleanup_execution_enabled",
        "export_execution_enabled",
        "remote_execution_enabled",
        "connector_write_enabled",
        "plugin_execution_enabled"
      ],
      "properties": {
        "dry_run_default": {"const": true},
        "execute_requires_confirmation": {"const": true},
        "only_safe_cleanup_execute_allowed": {"const": true},
        "source_of_truth_never_delete": {"const": true},
        "forbidden_source_prefixes": {"type": "array", "contains": {"const": "src/"}},
        "mutations_performed": {"type": "boolean"},
        "network_used": {"const": false},
        "external_api_used": {"const": false},
        "destructive_cleanup_performed": {"type": "boolean"},
        "source_mutations_performed": {"const": false},
        "cleanup_execution_enabled": {"type": "boolean"},
        "export_execution_enabled": {"const": false},
        "remote_execution_enabled": {"const": false},
        "connector_write_enabled": {"const": false},
        "plugin_execution_enabled": {"const": false}
      }
    }
  }
}
