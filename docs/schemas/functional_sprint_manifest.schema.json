{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://devpilot.local/schemas/SCHEMA-DEVPL-FUNCTIONAL-SPRINT-MANIFEST-V1",
  "title": "DevPilot Functional Sprint Manifest v1",
  "description": "Structural contract for docs/functional_sprint_XX_manifest.json files.",
  "type": "object",
  "required": [
    "title",
    "status",
    "phase",
    "created_files",
    "modified_files",
    "commands",
    "tests",
    "pass_criteria",
    "block_criteria",
    "risks",
    "next_sprint"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "sprint": {
      "type": "string",
      "pattern": "^FUNC-SPRINT-[0-9]{2}$"
    },
    "sprint_id": {
      "type": "string",
      "pattern": "^FUNC-SPRINT-[0-9]{2}$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "implemented",
        "approved",
        "closed",
        "draft",
        "planned"
      ]
    },
    "implemented_at": {
      "type": "string",
      "minLength": 1
    },
    "implemented_on": {
      "type": "string",
      "minLength": 1
    },
    "phase": {
      "type": "string",
      "minLength": 1
    },
    "wave": {
      "type": "string"
    },
    "source_backlog": {
      "type": "string"
    },
    "summary": {
      "type": [
        "string",
        "object"
      ]
    },
    "purpose": {
      "type": "string"
    },
    "precondition": {
      "type": "string"
    },
    "preliminary_notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "created_files": {
      "type": "array",
      "items": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "object"
          }
        ]
      },
      "minItems": 1
    },
    "modified_files": {
      "type": "array",
      "items": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "object"
          }
        ]
      },
      "minItems": 0
    },
    "commands": {
      "type": "array",
      "items": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "object"
          }
        ]
      },
      "minItems": 1
    },
    "tests": {
      "type": "array",
      "items": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "object"
          }
        ]
      },
      "minItems": 1
    },
    "pass_criteria": {
      "type": "array",
      "items": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "object"
          }
        ]
      },
      "minItems": 1
    },
    "block_criteria": {
      "type": "array",
      "items": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "object"
          }
        ]
      },
      "minItems": 1
    },
    "risks": {
      "type": "array",
      "items": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "object"
          }
        ]
      },
      "minItems": 1
    },
    "next_sprint": {
      "type": "string",
      "minLength": 1
    },
    "architectural_decision": {
      "type": "object"
    },
    "adr_required": {
      "type": "boolean"
    },
    "adr_rationale": {
      "type": "string"
    },
    "corrective_adjustments": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "closure_report": {
      "type": "string"
    },
    "release_manifest": {
      "type": "string"
    }
  },
  "additionalProperties": true,
  "x-devpilot-schema-id": "SCHEMA-DEVPL-FUNCTIONAL-SPRINT-MANIFEST-V1",
  "x-devpilot-version": "1.0.0",
  "x-devpilot-sprint": "FUNC-SPRINT-23",
  "x-devpilot-status": "registered",
  "x-devpilot-preliminary": true,
  "x-devpilot-validation-enabled-sprint": "FUNC-SPRINT-23",
  "x-devpilot-note": "Registered by FUNC-SPRINT-23 for structural validation. It complements but does not replace semantic/business validators.",
  "anyOf": [
    {
      "required": [
        "sprint"
      ]
    },
    {
      "required": [
        "sprint_id"
      ]
    }
  ],
  "allOf": [
    {
      "anyOf": [
        {
          "required": [
            "implemented_at"
          ]
        },
        {
          "required": [
            "implemented_on"
          ]
        }
      ]
    }
  ]
}
