{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://devpilot.local/schemas/SCHEMA-DEVPL-RELEASE-REPRODUCIBILITY-VERIFICATION-V1",
  "title": "DevPilot Release Reproducibility Verification v1",
  "description": "POST-H-017-D local verifier report for ReleaseReproducibilityPack evidence, dirty-state declaration, safety flags, generated snapshots and source archive checksums.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "schema_id",
    "verification_id",
    "created_by",
    "status",
    "generated_at_utc",
    "summary",
    "pack",
    "artifact_checks",
    "safety",
    "preliminary"
  ],
  "properties": {
    "schema_version": {"const": "1.0"},
    "schema_id": {"const": "SCHEMA-DEVPL-RELEASE-REPRODUCIBILITY-VERIFICATION-V1"},
    "verification_id": {"type": "string", "minLength": 8, "pattern": "^[a-z0-9_.:-]+$"},
    "created_by": {"const": "POST-H-017-D"},
    "status": {"enum": ["implemented-initial", "verified-local"]},
    "generated_at_utc": {"type": "string", "minLength": 10},
    "summary": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "created_by",
        "status",
        "pack_path",
        "release_reproducibility_verified",
        "blocking_findings_total",
        "local_first",
        "dry_run",
        "network_used",
        "external_api_used"
      ],
      "properties": {
        "created_by": {"const": "POST-H-017-D"},
        "status": {"enum": ["implemented-initial", "verified-local"]},
        "pack_path": {"type": "string", "minLength": 1},
        "release_reproducibility_verified": {"type": "boolean"},
        "blocking_findings_total": {"type": "integer", "minimum": 0},
        "local_first": {"const": true},
        "dry_run": {"const": true},
        "network_used": {"const": false},
        "external_api_used": {"const": false}
      }
    },
    "pack": {"type": "object", "additionalProperties": true},
    "artifact_checks": {"type": "object", "additionalProperties": true},
    "safety": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "local_first",
        "dry_run",
        "read_only",
        "network_used",
        "external_api_used",
        "remote_execution_used",
        "connector_write_used",
        "plugin_execution_used",
        "mutations_performed",
        "source_mutations_performed",
        "secrets_included"
      ],
      "properties": {
        "local_first": {"const": true},
        "dry_run": {"const": true},
        "read_only": {"const": true},
        "network_used": {"const": false},
        "external_api_used": {"const": false},
        "remote_execution_used": {"const": false},
        "connector_write_used": {"const": false},
        "plugin_execution_used": {"const": false},
        "mutations_performed": {"const": false},
        "source_mutations_performed": {"const": false},
        "secrets_included": {"const": false}
      }
    },
    "preliminary": {"const": true}
  }
}
