{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://devpilot.local/schemas/observability_inventory.schema.json",
  "title": "DevPilot Observability Inventory v1",
  "description": "POST-H-010-B read-only local inventory report for observability runtime targets declared in ObservabilityRetentionPolicy.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "schema_id",
    "inventory_id",
    "created_by",
    "status",
    "generated_at_utc",
    "policy_id",
    "policy_path",
    "targets_total",
    "target_checks",
    "findings",
    "summary",
    "safety",
    "notes"
  ],
  "properties": {
    "schema_version": {"const": "1.0"},
    "schema_id": {"const": "SCHEMA-DEVPL-OBSERVABILITY-INVENTORY-V1"},
    "inventory_id": {"const": "devpilot-local-observability-inventory"},
    "created_by": {"const": "POST-H-010-B"},
    "status": {"enum": ["implemented-initial"]},
    "generated_at_utc": {"type": "string", "minLength": 10},
    "policy_id": {"const": "devpilot-local-observability-retention"},
    "policy_path": {"type": "string", "minLength": 1},
    "targets_total": {"type": "integer", "minimum": 0},
    "target_checks": {"type": "array", "items": {"$ref": "#/$defs/target_check"}},
    "findings": {"type": "array", "items": {"$ref": "#/$defs/finding"}},
    "summary": {"$ref": "#/$defs/summary"},
    "safety": {"$ref": "#/$defs/safety"},
    "notes": {"type": "array", "items": {"type": "string", "minLength": 1}}
  },
  "$defs": {
    "target_check": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target_id",
        "path",
        "kind",
        "classification",
        "required",
        "exists",
        "inside_workspace",
        "size_bytes",
        "modified_at",
        "latest_child_modified_at",
        "records_estimated",
        "retention_days",
        "age_days",
        "expired",
        "max_size_mb",
        "size_exceeded",
        "rotation_enabled",
        "rotation_strategy",
        "rotation_recommended",
        "redaction_required",
        "contains_sensitive_payloads",
        "clean_zip_excluded",
        "clean_zip_risk",
        "export_allowed",
        "cleanup_allowed",
        "source_of_truth",
        "versionable",
        "raw_payload_storage_allowed",
        "logical_scope",
        "risk_level"
      ],
      "properties": {
        "target_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9_.-]*$"},
        "path": {"type": "string", "minLength": 1},
        "kind": {"enum": ["jsonl", "json", "sqlite", "sqlite-table", "directory", "file-glob", "directory-glob"]},
        "classification": {"enum": ["runtime-observability", "runtime-sensitive", "runtime-generated", "runtime-persistence"]},
        "required": {"type": "boolean"},
        "exists": {"type": "boolean"},
        "inside_workspace": {"type": "boolean"},
        "size_bytes": {"type": "integer", "minimum": 0},
        "modified_at": {"type": ["string", "null"]},
        "latest_child_modified_at": {"type": ["string", "null"]},
        "records_estimated": {"type": "integer", "minimum": 0},
        "retention_days": {"type": "integer", "minimum": 1},
        "age_days": {"type": ["integer", "null"], "minimum": 0},
        "expired": {"type": "boolean"},
        "max_size_mb": {"type": "number", "minimum": 0},
        "size_exceeded": {"type": "boolean"},
        "rotation_enabled": {"type": "boolean"},
        "rotation_strategy": {"enum": ["none", "size", "age", "size-or-age"]},
        "rotation_recommended": {"type": "boolean"},
        "redaction_required": {"type": "boolean"},
        "contains_sensitive_payloads": {"type": "boolean"},
        "clean_zip_excluded": {"type": "boolean"},
        "clean_zip_risk": {"type": "boolean"},
        "export_allowed": {"type": "boolean"},
        "cleanup_allowed": {"type": "boolean"},
        "source_of_truth": {"type": "boolean"},
        "versionable": {"type": "boolean"},
        "raw_payload_storage_allowed": {"type": "boolean"},
        "logical_scope": {"type": ["string", "null"]},
        "risk_level": {"enum": ["low", "medium", "medium-high", "high"]}
      }
    },
    "finding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "message", "severity"],
      "properties": {
        "id": {"type": "string", "pattern": "^[A-Z0-9_]+$"},
        "message": {"type": "string", "minLength": 1},
        "severity": {"enum": ["info", "warning", "fail", "block", "error"]},
        "path": {"type": "string"},
        "metadata": {"type": "object"}
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "policy_loaded",
        "created_by",
        "status",
        "preliminary",
        "read_only",
        "targets_total",
        "targets_existing_total",
        "targets_missing_total",
        "required_targets_missing_total",
        "targets_expired_total",
        "rotation_recommended_total",
        "redaction_required_total",
        "sensitive_existing_targets_total",
        "clean_zip_excluded_total",
        "clean_zip_risks_total",
        "bytes_total",
        "records_estimated_total",
        "warnings_total",
        "blocking_findings_total",
        "policy_validation_passed",
        "policy_id",
        "policy_path",
        "cleanup_execution_enabled",
        "export_execution_enabled",
        "redaction_execution_enabled",
        "raw_payloads_read",
        "network_used",
        "external_api_used",
        "mutations_performed",
        "destructive_cleanup_performed",
        "source_mutations_performed"
      ],
      "properties": {
        "policy_loaded": {"type": "boolean"},
        "created_by": {"const": "POST-H-010-B"},
        "status": {"enum": ["implemented-initial"]},
        "preliminary": {"const": true},
        "read_only": {"const": true},
        "targets_total": {"type": "integer", "minimum": 0},
        "targets_existing_total": {"type": "integer", "minimum": 0},
        "targets_missing_total": {"type": "integer", "minimum": 0},
        "required_targets_missing_total": {"type": "integer", "minimum": 0},
        "targets_expired_total": {"type": "integer", "minimum": 0},
        "rotation_recommended_total": {"type": "integer", "minimum": 0},
        "redaction_required_total": {"type": "integer", "minimum": 0},
        "sensitive_existing_targets_total": {"type": "integer", "minimum": 0},
        "clean_zip_excluded_total": {"type": "integer", "minimum": 0},
        "clean_zip_risks_total": {"type": "integer", "minimum": 0},
        "bytes_total": {"type": "integer", "minimum": 0},
        "records_estimated_total": {"type": "integer", "minimum": 0},
        "warnings_total": {"type": "integer", "minimum": 0},
        "blocking_findings_total": {"type": "integer", "minimum": 0},
        "policy_validation_passed": {"type": "boolean"},
        "policy_id": {"const": "devpilot-local-observability-retention"},
        "policy_path": {"type": "string", "minLength": 1},
        "cleanup_execution_enabled": {"const": false},
        "export_execution_enabled": {"const": false},
        "redaction_execution_enabled": {"const": false},
        "raw_payloads_read": {"const": false},
        "network_used": {"const": false},
        "external_api_used": {"const": false},
        "mutations_performed": {"const": false},
        "destructive_cleanup_performed": {"const": false},
        "source_mutations_performed": {"const": false},
        "reports_written": {"type": "boolean"},
        "output_json": {"type": ["string", "null"]},
        "output_markdown": {"type": ["string", "null"]}
      }
    },
    "safety": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "local_first",
        "read_only",
        "dry_run",
        "raw_payloads_read",
        "network_used",
        "external_api_used",
        "mutations_performed",
        "destructive_cleanup_performed",
        "source_mutations_performed",
        "cleanup_execution_enabled",
        "export_execution_enabled",
        "remote_execution_enabled",
        "connector_write_enabled",
        "plugin_execution_enabled"
      ],
      "properties": {
        "local_first": {"const": true},
        "read_only": {"const": true},
        "dry_run": {"const": true},
        "raw_payloads_read": {"const": false},
        "network_used": {"const": false},
        "external_api_used": {"const": false},
        "mutations_performed": {"const": false},
        "destructive_cleanup_performed": {"const": false},
        "source_mutations_performed": {"const": false},
        "cleanup_execution_enabled": {"const": false},
        "export_execution_enabled": {"const": false},
        "remote_execution_enabled": {"const": false},
        "connector_write_enabled": {"const": false},
        "plugin_execution_enabled": {"const": false}
      }
    }
  },
  "x-devpilot-schema-id": "SCHEMA-DEVPL-OBSERVABILITY-INVENTORY-V1",
  "x-devpilot-sprint": "POST-H-010-B",
  "x-devpilot-status": "registered"
}
