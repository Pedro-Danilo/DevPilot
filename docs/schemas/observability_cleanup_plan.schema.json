{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://devpilot.local/schemas/observability_cleanup_plan.schema.json",
  "title": "DevPilot Observability Cleanup Plan v1",
  "description": "POST-H-010-C dry-run-first cleanup, rotation, archive, redaction and export planning report for observability runtime targets declared in ObservabilityRetentionPolicy.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "schema_id",
    "cleanup_plan_id",
    "created_by",
    "status",
    "generated_at_utc",
    "policy_id",
    "policy_path",
    "inventory_id",
    "execution_mode",
    "actions",
    "blocked_actions",
    "required_approval_ids",
    "findings",
    "summary",
    "safety",
    "notes"
  ],
  "properties": {
    "schema_version": {"const": "1.0"},
    "schema_id": {"const": "SCHEMA-DEVPL-OBSERVABILITY-CLEANUP-PLAN-V1"},
    "cleanup_plan_id": {"const": "devpilot-local-observability-cleanup-plan"},
    "created_by": {"const": "POST-H-010-C"},
    "status": {"enum": ["implemented-initial"]},
    "generated_at_utc": {"type": "string", "minLength": 10},
    "policy_id": {"const": "devpilot-local-observability-retention"},
    "policy_path": {"type": "string", "minLength": 1},
    "inventory_id": {"const": "devpilot-local-observability-inventory"},
    "execution_mode": {"const": "dry-run"},
    "actions": {"type": "array", "items": {"$ref": "#/$defs/action"}},
    "blocked_actions": {"type": "array", "items": {"$ref": "#/$defs/action"}},
    "required_approval_ids": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "findings": {"type": "array", "items": {"$ref": "#/$defs/finding"}},
    "summary": {"$ref": "#/$defs/summary"},
    "safety": {"$ref": "#/$defs/safety"},
    "notes": {"type": "array", "items": {"type": "string", "minLength": 1}}
  },
  "$defs": {
    "action": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "action_id",
        "action_kind",
        "target_id",
        "path",
        "reason",
        "exists",
        "size_bytes",
        "age_days",
        "retention_days",
        "risk_level",
        "redaction_required",
        "contains_sensitive_payloads",
        "clean_zip_excluded",
        "requires_execute",
        "requires_policy_engine",
        "requires_approval",
        "required_approval_id",
        "blocked",
        "execution_status",
        "mutations_performed",
        "policy_evaluation"
      ],
      "properties": {
        "action_id": {"type": "string", "minLength": 1},
        "action_kind": {"enum": ["rotate", "delete", "archive", "redact", "export"]},
        "target_id": {"type": "string", "minLength": 1},
        "path": {"type": "string", "minLength": 1},
        "reason": {"type": "string", "minLength": 1},
        "exists": {"type": "boolean"},
        "size_bytes": {"type": "integer", "minimum": 0},
        "age_days": {"type": ["integer", "null"], "minimum": 0},
        "retention_days": {"type": "integer", "minimum": 0},
        "risk_level": {"enum": ["low", "medium", "medium-high", "high"]},
        "redaction_required": {"type": "boolean"},
        "contains_sensitive_payloads": {"type": "boolean"},
        "clean_zip_excluded": {"type": "boolean"},
        "requires_execute": {"type": "boolean"},
        "requires_policy_engine": {"type": "boolean"},
        "requires_approval": {"type": "boolean"},
        "required_approval_id": {"type": ["string", "null"]},
        "blocked": {"type": "boolean"},
        "execution_status": {"enum": ["planned", "blocked"]},
        "mutations_performed": {"const": false},
        "policy_evaluation": {"type": ["object", "null"]}
      }
    },
    "finding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "message", "severity"],
      "properties": {
        "id": {"type": "string", "pattern": "^[A-Z0-9_]+$"},
        "message": {"type": "string", "minLength": 1},
        "severity": {"enum": ["info", "warning", "fail", "block", "error"]},
        "path": {"type": "string"},
        "metadata": {"type": "object"}
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "created_by",
        "status",
        "preliminary",
        "policy_id",
        "policy_path",
        "inventory_id",
        "dry_run",
        "execute_requested",
        "execute_allowed",
        "execution_blocked",
        "explicit_execute_required_for_mutations",
        "read_only_plan",
        "actions_total",
        "actions_by_kind",
        "would_rotate",
        "would_delete",
        "would_archive",
        "would_redact",
        "would_export",
        "blocked_actions_total",
        "required_approval_ids_total",
        "targets_total",
        "targets_with_actions_total",
        "policy_evaluations_total",
        "warnings_total",
        "blocking_findings_total",
        "mutations_performed",
        "destructive_cleanup_performed",
        "source_mutations_performed",
        "cleanup_execution_enabled",
        "export_execution_enabled",
        "redaction_execution_enabled",
        "raw_payloads_read",
        "network_used",
        "external_api_used"
      ],
      "properties": {
        "created_by": {"const": "POST-H-010-C"},
        "status": {"const": "implemented-initial"},
        "preliminary": {"const": true},
        "policy_id": {"const": "devpilot-local-observability-retention"},
        "policy_path": {"type": "string", "minLength": 1},
        "inventory_id": {"const": "devpilot-local-observability-inventory"},
        "dry_run": {"const": true},
        "execute_requested": {"type": "boolean"},
        "execute_allowed": {"const": false},
        "execution_blocked": {"type": "boolean"},
        "explicit_execute_required_for_mutations": {"const": true},
        "read_only_plan": {"const": true},
        "actions_total": {"type": "integer", "minimum": 0},
        "actions_by_kind": {
          "type": "object",
          "additionalProperties": false,
          "required": ["rotate", "delete", "archive", "redact", "export"],
          "properties": {
            "rotate": {"type": "integer", "minimum": 0},
            "delete": {"type": "integer", "minimum": 0},
            "archive": {"type": "integer", "minimum": 0},
            "redact": {"type": "integer", "minimum": 0},
            "export": {"type": "integer", "minimum": 0}
          }
        },
        "would_rotate": {"type": "integer", "minimum": 0},
        "would_delete": {"type": "integer", "minimum": 0},
        "would_archive": {"type": "integer", "minimum": 0},
        "would_redact": {"type": "integer", "minimum": 0},
        "would_export": {"type": "integer", "minimum": 0},
        "blocked_actions_total": {"type": "integer", "minimum": 0},
        "required_approval_ids_total": {"type": "integer", "minimum": 0},
        "targets_total": {"type": "integer", "minimum": 0},
        "targets_with_actions_total": {"type": "integer", "minimum": 0},
        "policy_evaluations_total": {"type": "integer", "minimum": 0},
        "warnings_total": {"type": "integer", "minimum": 0},
        "blocking_findings_total": {"type": "integer", "minimum": 0},
        "mutations_performed": {"const": false},
        "destructive_cleanup_performed": {"const": false},
        "source_mutations_performed": {"const": false},
        "cleanup_execution_enabled": {"const": false},
        "export_execution_enabled": {"const": false},
        "redaction_execution_enabled": {"const": false},
        "raw_payloads_read": {"const": false},
        "network_used": {"const": false},
        "external_api_used": {"const": false},
        "reports_written": {"type": "boolean"},
        "output_json": {"type": ["string", "null"]},
        "output_markdown": {"type": ["string", "null"]}
      }
    },
    "safety": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "local_first",
        "dry_run_default",
        "plan_only",
        "execute_requires_approval",
        "policy_engine_required_for_mutations",
        "forbidden_source_prefixes",
        "mutations_performed",
        "destructive_cleanup_performed",
        "source_mutations_performed",
        "raw_payloads_read",
        "network_used",
        "external_api_used",
        "cleanup_execution_enabled",
        "export_execution_enabled",
        "remote_execution_enabled",
        "connector_write_enabled",
        "plugin_execution_enabled"
      ],
      "properties": {
        "local_first": {"const": true},
        "dry_run_default": {"const": true},
        "plan_only": {"const": true},
        "execute_requires_approval": {"const": true},
        "policy_engine_required_for_mutations": {"const": true},
        "forbidden_source_prefixes": {"type": "array", "contains": {"const": "src/"}},
        "mutations_performed": {"const": false},
        "destructive_cleanup_performed": {"const": false},
        "source_mutations_performed": {"const": false},
        "raw_payloads_read": {"const": false},
        "network_used": {"const": false},
        "external_api_used": {"const": false},
        "cleanup_execution_enabled": {"const": false},
        "export_execution_enabled": {"const": false},
        "remote_execution_enabled": {"const": false},
        "connector_write_enabled": {"const": false},
        "plugin_execution_enabled": {"const": false}
      }
    }
  },
  "x-devpilot-schema-id": "SCHEMA-DEVPL-OBSERVABILITY-CLEANUP-PLAN-V1",
  "x-devpilot-sprint": "POST-H-010-C",
  "x-devpilot-status": "registered"
}
