{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://devpilot.local/schemas/SCHEMA-DEVPL-WORKSPACE-ISOLATION-REPORT-V1",
  "title": "DevPilot Workspace Isolation Report v1",
  "description": "POST-H-016-B report contract for local read-only workspace root/state/outputs/traces isolation checks without reading secrets or state databases.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "schema_id",
    "report_id",
    "created_by",
    "status",
    "generated_at_utc",
    "registry_path",
    "summary",
    "workspaces",
    "findings",
    "safety"
  ],
  "properties": {
    "schema_version": {"const": "1.0"},
    "schema_id": {"const": "SCHEMA-DEVPL-WORKSPACE-ISOLATION-REPORT-V1"},
    "report_id": {"const": "workspace-isolation-report"},
    "created_by": {"const": "POST-H-016-B"},
    "status": {"const": "implemented-initial"},
    "generated_at_utc": {"type": "string", "minLength": 1},
    "registry_path": {"type": "string", "minLength": 1},
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "schema_id",
        "workspaces_total",
        "registered_workspaces_only",
        "path_guard_aligned",
        "state_paths_inside_workspace",
        "outputs_inside_workspace",
        "traces_inside_workspace",
        "secrets_shared_detected",
        "cross_workspace_refs_detected",
        "blocking_findings_total",
        "read_only",
        "dry_run",
        "network_used",
        "external_api_used",
        "shell_used",
        "remote_execution_used",
        "connector_write_used",
        "plugin_execution_used",
        "secrets_read",
        "state_files_read",
        "mutations_performed",
        "source_mutations_performed",
        "reports_written",
        "preliminary"
      ],
      "properties": {
        "schema_version": {"const": "1.0"},
        "schema_id": {"const": "SCHEMA-DEVPL-WORKSPACE-ISOLATION-REPORT-V1"},
        "workspaces_total": {"type": "integer", "minimum": 0},
        "active_workspace_id": {"type": ["string", "null"]},
        "registered_workspaces_only": {"const": true},
        "path_guard_aligned": {"type": "boolean"},
        "state_paths_inside_workspace": {"type": "boolean"},
        "outputs_inside_workspace": {"type": "boolean"},
        "traces_inside_workspace": {"type": "boolean"},
        "secrets_shared_detected": {"type": "boolean"},
        "cross_workspace_refs_detected": {"type": "boolean"},
        "blocking_findings_total": {"type": "integer", "minimum": 0},
        "read_only": {"const": true},
        "dry_run": {"const": true},
        "network_used": {"const": false},
        "external_api_used": {"const": false},
        "shell_used": {"const": false},
        "remote_execution_used": {"const": false},
        "connector_write_used": {"const": false},
        "plugin_execution_used": {"const": false},
        "secrets_read": {"const": false},
        "state_files_read": {"const": false},
        "mutations_performed": {"const": false},
        "source_mutations_performed": {"const": false},
        "reports_written": {"type": "boolean"},
        "preliminary": {"const": true}
      }
    },
    "workspaces": {
      "type": "array",
      "items": {"$ref": "#/$defs/workspace"}
    },
    "findings": {
      "type": "array",
      "items": {"$ref": "finding.schema.json"}
    },
    "safety": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "local_first",
        "read_only",
        "dry_run",
        "network_used",
        "external_api_used",
        "remote_execution_enabled",
        "connector_write_enabled",
        "plugin_execution_enabled",
        "secrets_read",
        "state_files_read",
        "source_mutations_performed"
      ],
      "properties": {
        "local_first": {"const": true},
        "read_only": {"const": true},
        "dry_run": {"const": true},
        "network_used": {"const": false},
        "external_api_used": {"const": false},
        "remote_execution_enabled": {"const": false},
        "connector_write_enabled": {"const": false},
        "plugin_execution_enabled": {"const": false},
        "secrets_read": {"const": false},
        "state_files_read": {"const": false},
        "source_mutations_performed": {"const": false}
      }
    }
  },
  "$defs": {
    "workspace": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "workspace_id",
        "root_path",
        "is_registered",
        "is_active",
        "project_file",
        "project_file_exists",
        "path_guard_root",
        "path_guard_root_matches_workspace_root",
        "root_path_allowed",
        "state_path",
        "state_path_inside_workspace",
        "outputs_path",
        "outputs_inside_workspace",
        "traces_path",
        "traces_inside_workspace",
        "secrets_path",
        "secrets_path_inside_workspace",
        "secrets_shared_detected",
        "cross_workspace_refs_detected",
        "cross_workspace_refs",
        "state_file_read",
        "secrets_read",
        "findings"
      ],
      "properties": {
        "workspace_id": {"type": "string", "minLength": 1},
        "root_path": {"type": "string", "minLength": 1},
        "is_registered": {"const": true},
        "is_active": {"type": "boolean"},
        "project_file": {"type": "string", "minLength": 1},
        "project_file_exists": {"type": "boolean"},
        "path_guard_root": {"type": "string", "minLength": 1},
        "path_guard_root_matches_workspace_root": {"type": "boolean"},
        "root_path_allowed": {"type": "boolean"},
        "state_path": {"type": "string", "minLength": 1},
        "state_path_inside_workspace": {"type": "boolean"},
        "outputs_path": {"type": "string", "minLength": 1},
        "outputs_inside_workspace": {"type": "boolean"},
        "traces_path": {"type": "string", "minLength": 1},
        "traces_inside_workspace": {"type": "boolean"},
        "secrets_path": {"type": "string", "minLength": 1},
        "secrets_path_inside_workspace": {"type": "boolean"},
        "secrets_shared_detected": {"const": false},
        "cross_workspace_refs_detected": {"type": "boolean"},
        "cross_workspace_refs": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["path_type", "owner_workspace_id", "path"],
            "properties": {
              "path_type": {"type": "string", "minLength": 1},
              "owner_workspace_id": {"type": "string", "minLength": 1},
              "path": {"type": "string", "minLength": 1}
            }
          }
        },
        "state_file_read": {"const": false},
        "secrets_read": {"const": false},
        "findings": {
          "type": "array",
          "items": {"$ref": "finding.schema.json"}
        }
      }
    }
  },
  "x-devpilot-schema-id": "SCHEMA-DEVPL-WORKSPACE-ISOLATION-REPORT-V1",
  "x-devpilot-version": "1.0.0",
  "x-devpilot-sprint": "POST-H-016-B",
  "x-devpilot-status": "registered",
  "x-devpilot-preliminary": true,
  "x-devpilot-note": "POST-H-016-B validates workspace isolation metadata only; it does not read secrets, state DB payloads, network, connectors or plugins."
}
