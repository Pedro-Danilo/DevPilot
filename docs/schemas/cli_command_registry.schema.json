{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://devpilot.local/schemas/cli_command_registry.schema.json",
  "title": "DevPilot CLI Command Registry v1",
  "description": "Static read-only registry of DevPilot CLI command groups, command descriptors, risks and safety invariants.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "schema_id",
    "registry_id",
    "generated_from",
    "created_by",
    "commands_total",
    "groups_total",
    "summary",
    "groups",
    "safety",
    "recommendations",
    "metadata"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "schema_id": {
      "const": "SCHEMA-DEVPL-CLI-COMMAND-REGISTRY-V1"
    },
    "registry_id": {
      "const": "devpilot-cli-command-registry"
    },
    "generated_from": {
      "type": "string",
      "minLength": 1
    },
    "created_by": {
      "enum": [
        "POST-H-006-A",
        "POST-H-006-B",
        "POST-H-006-C"
      ]
    },
    "commands_total": {
      "type": "integer",
      "minimum": 1
    },
    "groups_total": {
      "type": "integer",
      "minimum": 1
    },
    "summary": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "groups_total",
        "commands_total",
        "top_level_commands_total",
        "nested_commands_total",
        "dynamic_handler_loading_enabled",
        "remote_execution_enabled",
        "connector_write_enabled",
        "plugin_execution_enabled",
        "network_used",
        "external_api_used",
        "mutations_performed",
        "source_mutations_performed",
        "advisory_only",
        "preliminary"
      ],
      "properties": {
        "groups_total": {
          "type": "integer",
          "minimum": 1
        },
        "commands_total": {
          "type": "integer",
          "minimum": 1
        },
        "top_level_commands_total": {
          "type": "integer",
          "minimum": 0
        },
        "nested_commands_total": {
          "type": "integer",
          "minimum": 0
        },
        "commands_with_json_flag_total": {
          "type": "integer",
          "minimum": 0
        },
        "commands_with_write_report_total": {
          "type": "integer",
          "minimum": 0
        },
        "commands_with_dry_run_total": {
          "type": "integer",
          "minimum": 0
        },
        "commands_requiring_policy_total": {
          "type": "integer",
          "minimum": 0
        },
        "high_or_critical_risk_commands_total": {
          "type": "integer",
          "minimum": 0
        },
        "legacy_cli_owned_commands_total": {
          "type": "integer",
          "minimum": 0
        },
        "dynamic_handler_loading_enabled": {
          "const": false
        },
        "remote_execution_enabled": {
          "const": false
        },
        "connector_write_enabled": {
          "const": false
        },
        "plugin_execution_enabled": {
          "const": false
        },
        "network_used": {
          "const": false
        },
        "external_api_used": {
          "const": false
        },
        "mutations_performed": {
          "const": false
        },
        "source_mutations_performed": {
          "const": false
        },
        "advisory_only": {
          "const": true
        },
        "preliminary": {
          "const": true
        }
      }
    },
    "groups": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/group"
      }
    },
    "safety": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "remote_execution_enabled",
        "connector_write_enabled",
        "plugin_execution_enabled",
        "dynamic_handler_loading_enabled",
        "network_used",
        "external_api_used",
        "mutations_performed",
        "source_mutations_performed",
        "preliminary"
      ],
      "properties": {
        "remote_execution_enabled": {
          "const": false
        },
        "connector_write_enabled": {
          "const": false
        },
        "plugin_execution_enabled": {
          "const": false
        },
        "dynamic_handler_loading_enabled": {
          "const": false
        },
        "network_used": {
          "const": false
        },
        "external_api_used": {
          "const": false
        },
        "mutations_performed": {
          "const": false
        },
        "source_mutations_performed": {
          "const": false
        },
        "preliminary": {
          "const": true
        }
      }
    },
    "recommendations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "risk": {
      "enum": [
        "low",
        "medium",
        "high",
        "critical"
      ]
    },
    "sideEffect": {
      "enum": [
        "none",
        "write-report",
        "write-files",
        "mutate-state",
        "execute-subprocess",
        "potential-network"
      ]
    },
    "group": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "group_id",
        "domain",
        "owner_module",
        "risk_level",
        "application_service_required",
        "legacy_cli_owned",
        "commands_total",
        "commands"
      ],
      "properties": {
        "group_id": {
          "type": "string",
          "minLength": 1
        },
        "domain": {
          "type": "string",
          "minLength": 1
        },
        "owner_module": {
          "type": "string",
          "minLength": 1
        },
        "risk_level": {
          "$ref": "#/$defs/risk"
        },
        "application_service_required": {
          "type": "boolean"
        },
        "legacy_cli_owned": {
          "type": "boolean"
        },
        "commands_total": {
          "type": "integer",
          "minimum": 1
        },
        "commands": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/command"
          }
        }
      }
    },
    "command": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "command_id",
        "command_path",
        "public_invocation",
        "group_id",
        "domain",
        "owner_module",
        "handler",
        "returns",
        "risk_level",
        "side_effects",
        "writes_files",
        "dry_run_supported",
        "policy_check_required",
        "recommended_tests",
        "options",
        "legacy_cli_owned",
        "remote_execution_enabled",
        "connector_write_enabled",
        "plugin_execution_enabled",
        "metadata"
      ],
      "properties": {
        "command_id": {
          "type": "string",
          "minLength": 1
        },
        "command_path": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "public_invocation": {
          "type": "string",
          "pattern": "^python -m devpilot_core .+"
        },
        "group_id": {
          "type": "string",
          "minLength": 1
        },
        "domain": {
          "type": "string",
          "minLength": 1
        },
        "owner_module": {
          "type": "string",
          "minLength": 1
        },
        "handler": {
          "type": "string",
          "minLength": 1
        },
        "returns": {
          "const": "CommandResult"
        },
        "risk_level": {
          "$ref": "#/$defs/risk"
        },
        "side_effects": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/sideEffect"
          }
        },
        "writes_files": {
          "type": "boolean"
        },
        "dry_run_supported": {
          "type": "boolean"
        },
        "policy_check_required": {
          "type": "boolean"
        },
        "recommended_tests": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "options": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/option"
          }
        },
        "legacy_cli_owned": {
          "type": "boolean"
        },
        "remote_execution_enabled": {
          "const": false
        },
        "connector_write_enabled": {
          "const": false
        },
        "plugin_execution_enabled": {
          "const": false
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "option": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "option_strings",
        "required"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "option_strings": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "required": {
          "type": "boolean"
        },
        "action": {
          "type": "string"
        },
        "default": {},
        "help": {
          "type": "string"
        }
      }
    }
  }
}
