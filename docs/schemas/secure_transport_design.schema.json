        "external_api_used": {
          "const": false
        },
        "mutations_performed": {
          "const": false
        },
        "source_mutations_performed": {
          "const": false
        },
        "secrets_read": {
          "const": false
        },
        "certificates_generated": {
          "const": false
        }
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 2
