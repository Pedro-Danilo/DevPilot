{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://devpilot.local/schemas/observability_retention_hygiene.schema.json",
  "title": "DevPilot Observability Retention Hygiene v1",
  "description": "POST-H-010-E quality-gate report for local observability retention, metadata-only inventory and clean ZIP hygiene. The report is read-only, local-first and does not require runtime outputs to exist.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "schema_id",
    "report_id",
    "created_by",
    "status",
    "generated_at_utc",
    "policy_id",
    "policy_path",
    "inventory_id",
    "policy_checks",
    "inventory_checks",
    "source_archive_plan",
    "git_archive_check",
    "summary",
    "safety",
    "notes"
  ],
  "properties": {
    "schema_version": {"const": "1.0"},
    "schema_id": {"const": "SCHEMA-DEVPL-OBSERVABILITY-RETENTION-HYGIENE-V1"},
    "report_id": {"const": "devpilot-observability-retention-hygiene"},
    "created_by": {"const": "POST-H-010-E"},
    "status": {"const": "implemented-initial"},
    "generated_at_utc": {"type": "string", "minLength": 10},
    "policy_id": {"const": "devpilot-local-observability-retention"},
    "policy_path": {"type": "string", "minLength": 1},
    "inventory_id": {"const": "devpilot-local-observability-inventory"},
    "policy_checks": {"type": "array", "items": {"$ref": "#/$defs/check"}},
    "inventory_checks": {"$ref": "#/$defs/inventory_checks"},
    "source_archive_plan": {"$ref": "#/$defs/source_archive_plan"},
    "git_archive_check": {"$ref": "#/$defs/git_archive_check"},
    "summary": {"$ref": "#/$defs/summary"},
    "safety": {"$ref": "#/$defs/safety"},
    "notes": {"type": "array", "items": {"type": "string", "minLength": 1}}
  },
  "$defs": {
    "check": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "ok", "severity", "message"],
      "properties": {
        "id": {"type": "string", "pattern": "^[A-Z0-9_]+$"},
        "ok": {"type": "boolean"},
        "severity": {"enum": ["info", "warning", "fail", "block", "error"]},
        "message": {"type": "string", "minLength": 1},
        "path": {"type": "string"},
        "metadata": {"type": "object"}
      }
    },
    "inventory_checks": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "inventory_available",
        "targets_total",
        "targets_existing_total",
        "required_targets_missing_total",
        "clean_zip_risks_total",
        "rotation_recommended_total",
        "redaction_required_total",
        "warnings_total",
        "blocking_findings_total",
        "target_checks"
      ],
      "properties": {
        "inventory_available": {"type": "boolean"},
        "targets_total": {"type": "integer", "minimum": 0},
        "targets_existing_total": {"type": "integer", "minimum": 0},
        "required_targets_missing_total": {"type": "integer", "minimum": 0},
        "clean_zip_risks_total": {"type": "integer", "minimum": 0},
        "rotation_recommended_total": {"type": "integer", "minimum": 0},
        "redaction_required_total": {"type": "integer", "minimum": 0},
        "warnings_total": {"type": "integer", "minimum": 0},
        "blocking_findings_total": {"type": "integer", "minimum": 0},
        "target_checks": {"type": "array", "items": {"$ref": "#/$defs/check"}}
      }
    },
    "source_archive_plan": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "checked",
        "strategy",
        "clean",
        "included_files_total",
        "excluded_files_total",
        "forbidden_entries_total",
        "runtime_entries_total",
        "included_files_sha256",
        "forbidden_entries",
        "runtime_entries",
        "excluded_samples"
      ],
      "properties": {
        "checked": {"const": true},
        "strategy": {"const": "deterministic-source-archive-plan"},
        "clean": {"type": "boolean"},
        "included_files_total": {"type": "integer", "minimum": 0},
        "excluded_files_total": {"type": "integer", "minimum": 0},
        "forbidden_entries_total": {"type": "integer", "minimum": 0},
        "runtime_entries_total": {"type": "integer", "minimum": 0},
        "included_files_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "forbidden_entries": {"type": "array", "items": {"type": "object"}},
        "runtime_entries": {"type": "array", "items": {"type": "object"}},
        "excluded_samples": {"type": "array", "items": {"type": "object"}}
      }
    },
    "git_archive_check": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "available",
        "checked",
        "ok",
        "clean",
        "strategy",
        "entries_total",
        "entries_sha256",
        "forbidden_entries_total",
        "runtime_entries_total",
        "forbidden_entries",
        "runtime_entries",
        "reason"
      ],
      "properties": {
        "available": {"type": "boolean"},
        "checked": {"type": "boolean"},
        "ok": {"type": "boolean"},
        "clean": {"type": "boolean"},
        "strategy": {"const": "git-archive-head-in-memory"},
        "entries_total": {"type": "integer", "minimum": 0},
        "entries_sha256": {"type": ["string", "null"], "pattern": "^[a-f0-9]{64}$"},
        "forbidden_entries_total": {"type": "integer", "minimum": 0},
        "runtime_entries_total": {"type": "integer", "minimum": 0},
        "forbidden_entries": {"type": "array", "items": {"type": "object"}},
        "runtime_entries": {"type": "array", "items": {"type": "object"}},
        "reason": {"type": ["string", "null"]},
        "stderr_tail": {"type": "string"}
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "created_by",
        "status",
        "preliminary",
        "policy_id",
        "policy_path",
        "inventory_id",
        "dry_run",
        "read_only",
        "quality_gate_ready",
        "observability_retention_hygiene_passed",
        "policy_validation_passed",
        "inventory_validation_passed",
        "clean_zip_hygiene_passed",
        "source_archive_plan_checked",
        "source_archive_plan_clean",
        "git_archive_available",
        "git_archive_checked",
        "git_archive_clean",
        "targets_total",
        "inventory_targets_total",
        "inventory_missing_required_total",
        "inventory_clean_zip_risks_total",
        "rotation_recommended_total",
        "redaction_required_total",
        "forbidden_archive_entries_total",
        "runtime_archive_entries_total",
        "clean_zip_patterns_total",
        "blocking_reasons_total",
        "warnings_total",
        "blocking_findings_total",
        "reports_written",
        "output_json",
        "output_markdown",
        "raw_payloads_read",
        "network_used",
        "external_api_used",
        "mutations_performed",
        "destructive_cleanup_performed",
        "source_mutations_performed",
        "cleanup_execution_enabled",
        "export_execution_enabled",
        "redaction_execution_enabled",
        "remote_export_enabled",
        "connector_write_enabled",
        "plugin_execution_enabled"
      ],
      "properties": {
        "created_by": {"const": "POST-H-010-E"},
        "status": {"const": "implemented-initial"},
        "preliminary": {"const": true},
        "policy_id": {"const": "devpilot-local-observability-retention"},
        "policy_path": {"type": "string", "minLength": 1},
        "inventory_id": {"const": "devpilot-local-observability-inventory"},
        "dry_run": {"const": true},
        "read_only": {"const": true},
        "quality_gate_ready": {"type": "boolean"},
        "observability_retention_hygiene_passed": {"type": "boolean"},
        "policy_validation_passed": {"type": "boolean"},
        "inventory_validation_passed": {"type": "boolean"},
        "clean_zip_hygiene_passed": {"type": "boolean"},
        "source_archive_plan_checked": {"const": true},
        "source_archive_plan_clean": {"type": "boolean"},
        "git_archive_available": {"type": "boolean"},
        "git_archive_checked": {"type": "boolean"},
        "git_archive_clean": {"type": "boolean"},
        "targets_total": {"type": "integer", "minimum": 0},
        "inventory_targets_total": {"type": "integer", "minimum": 0},
        "inventory_missing_required_total": {"type": "integer", "minimum": 0},
        "inventory_clean_zip_risks_total": {"type": "integer", "minimum": 0},
        "rotation_recommended_total": {"type": "integer", "minimum": 0},
        "redaction_required_total": {"type": "integer", "minimum": 0},
        "forbidden_archive_entries_total": {"type": "integer", "minimum": 0},
        "runtime_archive_entries_total": {"type": "integer", "minimum": 0},
        "clean_zip_patterns_total": {"type": "integer", "minimum": 0},
        "blocking_reasons_total": {"type": "integer", "minimum": 0},
        "warnings_total": {"type": "integer", "minimum": 0},
        "blocking_findings_total": {"type": "integer", "minimum": 0},
        "reports_written": {"type": "boolean"},
        "output_json": {"type": ["string", "null"]},
        "output_markdown": {"type": ["string", "null"]},
        "raw_payloads_read": {"const": false},
        "network_used": {"const": false},
        "external_api_used": {"const": false},
        "mutations_performed": {"const": false},
        "destructive_cleanup_performed": {"const": false},
        "source_mutations_performed": {"const": false},
        "cleanup_execution_enabled": {"const": false},
        "export_execution_enabled": {"const": false},
        "redaction_execution_enabled": {"const": false},
        "remote_export_enabled": {"const": false},
        "connector_write_enabled": {"const": false},
        "plugin_execution_enabled": {"const": false}
      }
    },
    "safety": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "local_first",
        "read_only",
        "dry_run_default",
        "raw_payloads_read",
        "network_used",
        "external_api_used",
        "mutations_performed",
        "destructive_cleanup_performed",
        "source_mutations_performed",
        "cleanup_execution_enabled",
        "export_execution_enabled",
        "redaction_execution_enabled",
        "remote_export_enabled",
        "connector_write_enabled",
        "plugin_execution_enabled",
        "zip_hygiene_enforced"
      ],
      "properties": {
        "local_first": {"const": true},
        "read_only": {"const": true},
        "dry_run_default": {"const": true},
        "raw_payloads_read": {"const": false},
        "network_used": {"const": false},
        "external_api_used": {"const": false},
        "mutations_performed": {"const": false},
        "destructive_cleanup_performed": {"const": false},
        "source_mutations_performed": {"const": false},
        "cleanup_execution_enabled": {"const": false},
        "export_execution_enabled": {"const": false},
        "redaction_execution_enabled": {"const": false},
        "remote_export_enabled": {"const": false},
        "connector_write_enabled": {"const": false},
        "plugin_execution_enabled": {"const": false},
        "zip_hygiene_enforced": {"const": true}
      }
    }
  },
  "x-devpilot": {
    "schema_id": "SCHEMA-DEVPL-OBSERVABILITY-RETENTION-HYGIENE-V1",
    "contract": "ObservabilityRetentionHygiene",
    "owner": "Ordóñez",
    "sprint": "POST-H-010-E",
    "status": "registered",
    "local_first": true,
    "remote_export_enabled": false,
    "network_required": false,
    "external_api_required": false
  }
}
