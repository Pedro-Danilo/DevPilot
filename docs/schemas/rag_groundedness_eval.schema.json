{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://devpilot.local/schemas/rag_groundedness_eval.schema.json",
  "title": "DevPilot RAG Groundedness Eval Suite v1",
  "description": "POST-H-011-A local-first fixture schema for deterministic RAG groundedness evaluation cases. It defines expected local sources, required claims, forbidden claims and safety flags without requiring external APIs, web search, embeddings or LLM judge.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "schema_id",
    "suite_id",
    "created_by",
    "status",
    "version",
    "owner",
    "generated_at_utc",
    "description",
    "local_first",
    "dry_run",
    "network_used",
    "external_api_used",
    "web_search_used",
    "llm_judge_required",
    "remote_execution_enabled",
    "connector_write_enabled",
    "plugin_execution_enabled",
    "minimum_cases_required",
    "cases",
    "suite_defaults",
    "notes"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "schema_id": {
      "const": "SCHEMA-DEVPL-RAG-GROUNDEDNESS-EVAL-V1"
    },
    "suite_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "created_by": {
      "const": "POST-H-011-A"
    },
    "status": {
      "enum": [
        "implemented-initial",
        "approved"
      ]
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "generated_at_utc": {
      "type": "string",
      "minLength": 10
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "local_first": {
      "const": true
    },
    "dry_run": {
      "const": true
    },
    "network_used": {
      "const": false
    },
    "external_api_used": {
      "const": false
    },
    "web_search_used": {
      "const": false
    },
    "llm_judge_required": {
      "const": false
    },
    "remote_execution_enabled": {
      "const": false
    },
    "connector_write_enabled": {
      "const": false
    },
    "plugin_execution_enabled": {
      "const": false
    },
    "minimum_cases_required": {
      "type": "integer",
      "minimum": 10
    },
    "suite_defaults": {
      "$ref": "#/$defs/suite_defaults"
    },
    "cases": {
      "type": "array",
      "minItems": 10,
      "items": {
        "$ref": "#/$defs/case"
      },
      "uniqueItems": true
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    }
  },
  "$defs": {
    "suite_defaults": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "minimum_source_coverage",
        "minimum_claim_support",
        "forbidden_claims_block",
        "expected_sources_required",
        "canonical_sources_only",
        "outputs_as_sources_allowed"
      ],
      "properties": {
        "minimum_source_coverage": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "minimum_claim_support": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "forbidden_claims_block": {
          "const": true
        },
        "expected_sources_required": {
          "const": true
        },
        "canonical_sources_only": {
          "const": true
        },
        "outputs_as_sources_allowed": {
          "const": false
        }
      }
    },
    "case": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "case_id",
        "question",
        "case_type",
        "domain",
        "expected_sources",
        "required_claims",
        "forbidden_claims",
        "minimum_source_coverage",
        "minimum_claim_support",
        "risk_level",
        "expected_behavior",
        "tags"
      ],
      "properties": {
        "case_id": {
          "type": "string",
          "pattern": "^rag-posth-[a-z0-9-]+$"
        },
        "question": {
          "type": "string",
          "minLength": 10
        },
        "case_type": {
          "enum": [
            "positive",
            "negative",
            "mixed"
          ]
        },
        "domain": {
          "enum": [
            "roadmap",
            "security",
            "testing",
            "architecture",
            "onboarding",
            "operations",
            "release",
            "rag",
            "governance"
          ]
        },
        "expected_sources": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1,
            "not": {
              "pattern": "^outputs/"
            }
          },
          "uniqueItems": true
        },
        "required_claims": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "forbidden_claims": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "minimum_source_coverage": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "minimum_claim_support": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "risk_level": {
          "enum": [
            "low",
            "medium",
            "high",
            "critical"
          ]
        },
        "expected_behavior": {
          "enum": [
            "pass_with_sources",
            "warn_low_coverage",
            "block_forbidden_claim",
            "block_missing_sources"
          ]
        },
        "tags": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$"
          },
          "uniqueItems": true
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
