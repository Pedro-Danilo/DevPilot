{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://devpilot.local/schemas/observability_redacted_export.schema.json",
  "title": "DevPilot Observability Redacted Export v1",
  "description": "POST-H-010-D local redacted export schema for observability evidence summaries, checksums and safety gates without raw prompts, raw outputs, secrets, network or remote export.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "schema_id",
    "export_id",
    "created_by",
    "status",
    "generated_at_utc",
    "policy_id",
    "policy_path",
    "inventory_id",
    "redacted",
    "redaction_applied",
    "target_exports",
    "sections",
    "checksums",
    "findings",
    "summary",
    "safety",
    "notes"
  ],
  "properties": {
    "schema_version": {"const": "1.0"},
    "schema_id": {"const": "SCHEMA-DEVPL-OBSERVABILITY-REDACTED-EXPORT-V1"},
    "export_id": {"type": "string", "pattern": "^observability-redacted-export-[a-f0-9]{12}$"},
    "created_by": {"const": "POST-H-010-D"},
    "status": {"const": "implemented-initial"},
    "generated_at_utc": {"type": "string", "minLength": 10},
    "policy_id": {"const": "devpilot-local-observability-retention"},
    "policy_path": {"type": "string", "minLength": 1},
    "inventory_id": {"const": "devpilot-local-observability-inventory"},
    "redacted": {"const": true},
    "redaction_applied": {"const": true},
    "target_exports": {"type": "array", "items": {"$ref": "#/$defs/target_export"}},
    "sections": {"$ref": "#/$defs/sections"},
    "checksums": {"type": "object", "additionalProperties": {"type": "string", "pattern": "^[a-f0-9]{64}$"}},
    "findings": {"type": "array", "items": {"$ref": "#/$defs/finding"}},
    "summary": {"$ref": "#/$defs/summary"},
    "safety": {"$ref": "#/$defs/safety"},
    "notes": {"type": "array", "items": {"type": "string", "minLength": 1}}
  },
  "$defs": {
    "target_export": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target_id",
        "path",
        "kind",
        "exists",
        "size_bytes",
        "records_estimated",
        "redaction_required",
        "contains_sensitive_payloads",
        "clean_zip_excluded",
        "export_allowed",
        "export_mode",
        "raw_payload_exported"
      ],
      "properties": {
        "target_id": {"type": "string", "minLength": 1},
        "path": {"type": "string", "minLength": 1},
        "kind": {"type": "string", "minLength": 1},
        "exists": {"type": "boolean"},
        "size_bytes": {"type": "integer", "minimum": 0},
        "records_estimated": {"type": "integer", "minimum": 0},
        "redaction_required": {"type": "boolean"},
        "contains_sensitive_payloads": {"type": "boolean"},
        "clean_zip_excluded": {"type": "boolean"},
        "export_allowed": {"type": "boolean"},
        "export_mode": {"enum": ["metadata-only", "summary-only"]},
        "raw_payload_exported": {"const": false}
      }
    },
    "sections": {
      "type": "object",
      "additionalProperties": false,
      "required": ["events", "spans", "metrics", "agent_sessions", "reports"],
      "properties": {
        "events": {"type": "object"},
        "spans": {"type": "object"},
        "metrics": {"type": "object"},
        "agent_sessions": {"type": "object"},
        "reports": {"type": "object"}
      }
    },
    "finding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "message", "severity"],
      "properties": {
        "id": {"type": "string", "pattern": "^[A-Z0-9_]+$"},
        "message": {"type": "string", "minLength": 1},
        "severity": {"enum": ["info", "warning", "fail", "block", "error"]},
        "path": {"type": "string"},
        "metadata": {"type": "object"}
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "created_by",
        "status",
        "preliminary",
        "redacted",
        "execution_blocked",
        "redaction_required",
        "redaction_applied",
        "generated_at_utc",
        "export_id",
        "policy_id",
        "policy_path",
        "inventory_id",
        "targets_total",
        "target_exports_total",
        "sections_total",
        "events_exported_total",
        "spans_exported_total",
        "metrics_exported_total",
        "agent_sessions_exported_total",
        "report_metadata_exported_total",
        "records_exported_total",
        "redactions_total",
        "raw_payload_fields_removed_total",
        "checksums_total",
        "raw_prompts_exported",
        "raw_outputs_exported",
        "secrets_exported",
        "env_files_exported",
        "sqlite_raw_exported",
        "remote_export_enabled",
        "export_execution_enabled",
        "redaction_execution_enabled",
        "cleanup_execution_enabled",
        "mutations_performed",
        "destructive_cleanup_performed",
        "source_mutations_performed",
        "raw_payloads_read",
        "network_used",
        "external_api_used",
        "reports_written",
        "audit_export_written",
        "audit_export_path",
        "output_json",
        "output_markdown",
        "limit"
      ],
      "properties": {
        "created_by": {"const": "POST-H-010-D"},
        "status": {"const": "implemented-initial"},
        "preliminary": {"const": true},
        "redacted": {"const": true},
        "execution_blocked": {"type": "boolean"},
        "redaction_required": {"const": true},
        "redaction_applied": {"const": true},
        "generated_at_utc": {"type": "string", "minLength": 10},
        "export_id": {"type": "string", "minLength": 1},
        "policy_id": {"const": "devpilot-local-observability-retention"},
        "policy_path": {"type": "string", "minLength": 1},
        "inventory_id": {"const": "devpilot-local-observability-inventory"},
        "targets_total": {"type": "integer", "minimum": 0},
        "target_exports_total": {"type": "integer", "minimum": 0},
        "sections_total": {"type": "integer", "minimum": 0},
        "events_exported_total": {"type": "integer", "minimum": 0},
        "spans_exported_total": {"type": "integer", "minimum": 0},
        "metrics_exported_total": {"type": "integer", "minimum": 0},
        "agent_sessions_exported_total": {"type": "integer", "minimum": 0},
        "report_metadata_exported_total": {"type": "integer", "minimum": 0},
        "records_exported_total": {"type": "integer", "minimum": 0},
        "redactions_total": {"type": "integer", "minimum": 0},
        "raw_payload_fields_removed_total": {"type": "integer", "minimum": 0},
        "checksums_total": {"type": "integer", "minimum": 0},
        "raw_prompts_exported": {"const": false},
        "raw_outputs_exported": {"const": false},
        "secrets_exported": {"const": false},
        "env_files_exported": {"const": false},
        "sqlite_raw_exported": {"const": false},
        "remote_export_enabled": {"const": false},
        "export_execution_enabled": {"const": true},
        "redaction_execution_enabled": {"const": true},
        "cleanup_execution_enabled": {"const": false},
        "mutations_performed": {"const": false},
        "destructive_cleanup_performed": {"const": false},
        "source_mutations_performed": {"const": false},
        "raw_payloads_read": {"const": false},
        "network_used": {"const": false},
        "external_api_used": {"const": false},
        "reports_written": {"type": "boolean"},
        "audit_export_written": {"type": "boolean"},
        "audit_export_path": {"type": ["string", "null"]},
        "output_json": {"type": ["string", "null"]},
        "output_markdown": {"type": ["string", "null"]},
        "limit": {"type": "integer", "minimum": 1, "maximum": 500}
      }
    },
    "safety": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "local_first",
        "redaction_required",
        "redaction_applied",
        "no_raw_prompts",
        "no_raw_outputs",
        "no_secrets",
        "no_env_files",
        "metadata_only_for_sqlite",
        "metadata_only_for_agent_sessions",
        "network_used",
        "external_api_used",
        "remote_export_enabled",
        "cleanup_execution_enabled",
        "destructive_cleanup_performed",
        "source_mutations_performed",
        "connector_write_enabled",
        "plugin_execution_enabled"
      ],
      "properties": {
        "local_first": {"const": true},
        "redaction_required": {"const": true},
        "redaction_applied": {"const": true},
        "no_raw_prompts": {"const": true},
        "no_raw_outputs": {"const": true},
        "no_secrets": {"const": true},
        "no_env_files": {"const": true},
        "metadata_only_for_sqlite": {"const": true},
        "metadata_only_for_agent_sessions": {"const": true},
        "network_used": {"const": false},
        "external_api_used": {"const": false},
        "remote_export_enabled": {"const": false},
        "cleanup_execution_enabled": {"const": false},
        "destructive_cleanup_performed": {"const": false},
        "source_mutations_performed": {"const": false},
        "connector_write_enabled": {"const": false},
        "plugin_execution_enabled": {"const": false}
      }
    }
  }
}
