{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://devpilot.local/schemas/SCHEMA-DEVPL-PROVIDER-CONFIG-V2",
  "title": "DevPilot Provider Config v2",
  "description": "Structural and safety contract for .devpilot/providers.yaml(.example). Raw secrets are denied; mock is required; local providers are localhost-only; external API providers remain disabled by default.",
  "type": "object",
  "required": [
    "schema_version",
    "providers"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "enum": [
        "2.0"
      ]
    },
    "providers": {
      "type": "array",
      "minItems": 1,
      "contains": {
        "type": "object",
        "properties": {
          "id": {
            "const": "mock"
          },
          "enabled": {
            "const": true
          },
          "kind": {
            "const": "mock"
          }
        },
        "required": [
          "id",
          "enabled",
          "kind"
        ]
      },
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "kind",
          "enabled",
          "default_model",
          "external_api",
          "requires_api_key",
          "estimated_cost_per_1k_tokens_usd",
          "status"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_-]*$"
          },
          "kind": {
            "type": "string",
            "enum": [
              "mock",
              "local",
              "api"
            ]
          },
          "enabled": {
            "type": "boolean"
          },
          "default_model": {
            "type": "string",
            "minLength": 1
          },
          "endpoint": {
            "type": "string",
            "minLength": 1
          },
          "external_api": {
            "type": "boolean"
          },
          "requires_api_key": {
            "type": "boolean"
          },
          "api_key_env": {
            "type": "string",
            "pattern": "^[A-Z][A-Z0-9_]*$"
          },
          "estimated_cost_per_1k_tokens_usd": {
            "type": "number",
            "minimum": 0
          },
          "status": {
            "type": "string",
            "enum": [
              "implemented",
              "implemented-initial",
              "planned",
              "disabled",
              "future"
            ]
          },
          "notes": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "default": []
          }
        },
        "allOf": [
          {
            "if": {
              "properties": {
                "kind": {
                  "const": "mock"
                }
              },
              "required": [
                "kind"
              ]
            },
            "then": {
              "properties": {
                "enabled": {
                  "const": true
                },
                "external_api": {
                  "const": false
                },
                "requires_api_key": {
                  "const": false
                },
                "status": {
                  "const": "implemented"
                }
              }
            }
          },
          {
            "if": {
              "properties": {
                "kind": {
                  "const": "local"
                }
              },
              "required": [
                "kind"
              ]
            },
            "then": {
              "required": [
                "endpoint"
              ],
              "properties": {
                "external_api": {
                  "const": false
                },
                "requires_api_key": {
                  "const": false
                },
                "status": {
                  "enum": [
                    "planned",
                    "implemented-initial",
                    "disabled",
                    "future"
                  ]
                },
                "endpoint": {
                  "pattern": "^http://(localhost|127\\.0\\.0\\.1|\\[::1\\])(:[0-9]+)?(/.*)?$"
                }
              }
            }
          },
          {
            "if": {
              "properties": {
                "kind": {
                  "const": "api"
                }
              },
              "required": [
                "kind"
              ]
            },
            "then": {
              "required": [
                "api_key_env",
                "endpoint"
              ],
              "properties": {
                "enabled": {
                  "const": false
                },
                "external_api": {
                  "const": true
                },
                "requires_api_key": {
                  "const": true
                },
                "status": {
                  "const": "disabled"
                },
                "endpoint": {
                  "pattern": "^https://"
                }
              }
            }
          }
        ]
      }
    }
  },
  "additionalProperties": false,
  "x-devpilot-schema-id": "SCHEMA-DEVPL-PROVIDER-CONFIG-V2",
  "x-devpilot-version": "2.0.0",
  "x-devpilot-sprint": "FUNC-SPRINT-45",
  "x-devpilot-status": "registered",
  "x-devpilot-preliminary": true,
  "x-devpilot-validation-enabled-sprint": "FUNC-SPRINT-45",
  "x-devpilot-note": "FUNC-SPRINT-45 hardens provider metadata contracts before local adapters are implemented.",
  "not": {
    "required": [
      "api_key"
    ]
  }
}
