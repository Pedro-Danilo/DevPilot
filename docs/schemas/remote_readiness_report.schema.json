        "remote_runner_enabled",
        "remote_execution_used",
        "network_required",
        "external_api_required",
        "secrets_required",
        "credentials_required",
        "mutations_performed",
        "source_mutations_performed",
        "connector_write_enabled",
        "plugin_execution_enabled"
      ],
      "properties": {
        "remote_runner_enabled": {"const": false},
        "remote_execution_used": {"const": false},
        "network_required": {"const": false},
        "external_api_required": {"const": false},
        "secrets_required": {"const": false},
        "credentials_required": {"const": false},
        "mutations_performed": {"const": false},
        "source_mutations_performed": {"const": false},
        "connector_write_enabled": {"const": false},
        "plugin_execution_enabled": {"const": false}
      }
    },
    "findings": {
      "type": "array",
      "items": {"type": "object"}
    },
    "safety": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "local_first",
