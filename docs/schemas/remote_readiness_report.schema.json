    "secrets_read": {"const": false},
    "blocking_findings_total": {"type": "integer", "minimum": 0},
    "summary": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "created_by",
        "readiness_level",
        "decision_status",
        "remote_execution_allowed",
        "remote_runner_enabled",
        "execution_allowed",
        "remote_execution_used",
        "network_used",
        "external_api_used",
        "credentials_required",
        "secrets_read",
        "mutations_performed",
        "source_mutations_performed",
        "requires_future_adr",
