{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://devpilot.local/schemas/runtime_state_export_manifest.schema.json",
  "title": "DevPilot Runtime State Export Manifest v1",
  "type": "object",
  "required": [
    "schema_version",
    "schema_id",
    "export_id",
    "created_by",
    "status",
    "generated_at_utc",
    "policy_path",
    "output_path",
    "dry_run",
    "execute_requested",
    "entries",
    "checksums",
    "summary",
    "safety"
  ],
  "properties": {
    "schema_version": {"const": "1.0"},
    "schema_id": {"const": "SCHEMA-DEVPL-RUNTIME-STATE-EXPORT-MANIFEST-V1"},
    "export_id": {"type": "string", "minLength": 1},
    "created_by": {"const": "POST-H-008-D"},
    "status": {"enum": ["implemented-initial", "closed"]},
    "generated_at_utc": {"type": "string", "minLength": 1},
    "policy_path": {"type": "string", "minLength": 1},
    "inventory_id": {"type": ["string", "null"]},
    "output_path": {"type": "string", "minLength": 1},
    "manifest_path": {"type": "string"},
    "checksums_path": {"type": "string"},
    "dry_run": {"type": "boolean"},
    "execute_requested": {"type": "boolean"},
    "entries": {
      "type": "array",
      "items": {"$ref": "#/$defs/entry"}
    },
    "checksums": {
      "type": "object",
      "additionalProperties": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
    },
    "summary": {"$ref": "#/$defs/summary"},
    "safety": {"$ref": "#/$defs/safety"},
    "notes": {"type": "array", "items": {"type": "string"}}
  },
  "$defs": {
    "entry": {
      "type": "object",
      "required": [
        "original_path",
        "export_path",
        "class_id",
        "source_size_bytes",
        "exported_size_bytes",
        "source_sha256",
        "export_sha256",
        "redacted",
        "redactions_total",
        "raw_payload_fields_removed",
        "raw_prompt_exported",
        "raw_output_exported",
        "secret_scan_passed",
        "metadata_only",
        "checksum_algorithm"
      ],
      "properties": {
        "original_path": {"type": "string", "minLength": 1},
        "export_path": {"type": "string", "minLength": 1},
        "class_id": {"type": "string", "minLength": 1},
        "classification": {"type": ["string", "null"]},
        "source_size_bytes": {"type": "integer", "minimum": 0},
        "exported_size_bytes": {"type": "integer", "minimum": 0},
        "source_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "export_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "redacted": {"type": "boolean"},
        "redactions_total": {"type": "integer", "minimum": 0},
        "raw_payload_fields_removed": {"type": "integer", "minimum": 0},
        "raw_prompt_exported": {"const": false},
        "raw_output_exported": {"const": false},
        "secret_scan_passed": {"const": true},
        "metadata_only": {"type": "boolean"},
        "checksum_algorithm": {"const": "sha256"}
      },
      "additionalProperties": true
    },
    "summary": {
      "type": "object",
      "required": [
        "created_by",
        "status",
        "preliminary",
        "dry_run",
        "execute_requested",
        "export_execution_enabled",
        "redaction_execution_enabled",
        "network_used",
        "external_api_used",
        "mutations_performed",
        "source_mutations_performed",
        "planned_entries_total",
        "files_exported_total",
        "redactions_total",
        "checksums_total",
        "raw_prompts_exported",
        "raw_outputs_exported",
        "secrets_exported",
        "local_db_raw_exported"
      ],
      "properties": {
        "created_by": {"const": "POST-H-008-D"},
        "status": {"enum": ["implemented-initial", "closed"]},
        "preliminary": {"type": "boolean"},
        "dry_run": {"type": "boolean"},
        "execute_requested": {"type": "boolean"},
        "execution_blocked": {"type": "boolean"},
        "output_path": {"type": "string"},
        "planned_entries_total": {"type": "integer", "minimum": 0},
        "files_exported_total": {"type": "integer", "minimum": 0},
        "metadata_only_total": {"type": "integer", "minimum": 0},
        "skipped_non_exportable_total": {"type": "integer", "minimum": 0},
        "redactions_total": {"type": "integer", "minimum": 0},
        "raw_payload_fields_removed_total": {"type": "integer", "minimum": 0},
        "checksums_total": {"type": "integer", "minimum": 0},
        "manifest_written": {"type": "boolean"},
        "checksums_written": {"type": "boolean"},
        "raw_prompts_exported": {"const": false},
        "raw_outputs_exported": {"const": false},
        "secrets_exported": {"const": false},
        "local_db_raw_exported": {"const": false},
        "auditpack_optional_source_ready": {"type": "boolean"},
        "cleanup_execution_enabled": {"type": "boolean"},
        "export_execution_enabled": {"type": "boolean"},
        "redaction_execution_enabled": {"type": "boolean"},
        "network_used": {"const": false},
        "external_api_used": {"const": false},
        "mutations_performed": {"type": "boolean"},
        "destructive_cleanup_performed": {"const": false},
        "source_mutations_performed": {"const": false}
      },
      "additionalProperties": true
    },
    "safety": {
      "type": "object",
      "required": [
        "dry_run_default",
        "execute_requires_explicit_output",
        "redaction_required_for_sensitive_artifacts",
        "no_raw_prompts",
        "no_raw_outputs",
        "secretguard_enabled",
        "local_db_metadata_only",
        "network_used",
        "external_api_used",
        "remote_execution_enabled",
        "connector_write_enabled",
        "plugin_execution_enabled",
        "source_mutations_performed"
      ],
      "properties": {
        "dry_run_default": {"const": true},
        "execute_requires_explicit_output": {"const": true},
        "redaction_required_for_sensitive_artifacts": {"const": true},
        "no_raw_prompts": {"const": true},
        "no_raw_outputs": {"const": true},
        "secretguard_enabled": {"const": true},
        "local_db_metadata_only": {"const": true},
        "network_used": {"const": false},
        "external_api_used": {"const": false},
        "remote_execution_enabled": {"const": false},
        "connector_write_enabled": {"const": false},
        "plugin_execution_enabled": {"const": false},
        "source_mutations_performed": {"const": false}
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
