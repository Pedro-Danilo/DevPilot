{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://devpilot.local/schemas/SCHEMA-DEVPL-ENTERPRISE-THREAT-MODEL-V1",
  "title": "DevPilot EnterpriseThreatModel v1",
  "description": "Design-only contract for POST-H-022 enterprise deployment threat modeling. It inventories assets, actors, trust boundaries and no-go gates without enabling enterprise deployment, remote execution, network services, secure transport or compliance certification claims.",
  "type": "object",
  "required": [
    "schema_version",
    "schema_id",
    "created_by",
    "updated",
    "status",
    "decision_status",
    "enterprise_deployment_enabled",
    "production_multiuser_enabled",
    "control_plane_enabled",
    "remote_execution_enabled",
    "secure_transport_implemented",
    "compliance_certification_claim",
    "assets",
    "actors",
    "trust_boundaries",
    "data_flows",
    "no_go_gates",
    "safety",
    "threat_catalog_summary",
    "threat_catalog",
    "required_controls",
    "residual_risks"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "schema_id": {
      "type": "string",
      "const": "SCHEMA-DEVPL-ENTERPRISE-THREAT-MODEL-V1"
    },
    "created_by": {
      "type": "string",
      "const": "POST-H-022-A"
    },
    "updated": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "implemented-initial",
        "approved"
      ]
    },
    "decision_status": {
      "type": "string",
      "const": "design-only"
    },
    "enterprise_deployment_enabled": {
      "type": "boolean",
      "const": false
    },
    "production_multiuser_enabled": {
      "type": "boolean",
      "const": false
    },
    "control_plane_enabled": {
      "type": "boolean",
      "const": false
    },
    "remote_execution_enabled": {
      "type": "boolean",
      "const": false
    },
    "secure_transport_implemented": {
      "type": "boolean",
      "const": false
    },
    "compliance_certification_claim": {
      "type": "boolean",
      "const": false
    },
    "assets": {
      "type": "array",
      "minItems": 8,
      "items": {
        "type": "object",
        "required": [
          "asset_id",
          "title",
          "category",
          "sensitivity",
          "current_location",
          "enterprise_relevance",
          "current_boundary",
          "future_boundary",
          "no_go_notes"
        ],
        "properties": {
          "asset_id": {
            "type": "string",
            "minLength": 1
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "category": {
            "type": "string",
            "enum": [
              "workspace",
              "source_code",
              "state_store",
              "reports",
              "traces",
              "approvals",
              "secrets",
              "identity",
              "policy",
              "compliance",
              "audit",
              "api",
              "ui",
              "release",
              "remote_design"
            ]
          },
          "sensitivity": {
            "type": "string",
            "enum": [
              "public",
              "internal",
              "confidential",
              "restricted"
            ]
          },
          "current_location": {
            "type": "string",
            "minLength": 1
          },
          "enterprise_relevance": {
            "type": "string",
            "minLength": 1
          },
          "current_boundary": {
            "type": "string",
            "minLength": 1
          },
          "future_boundary": {
            "type": "string",
            "minLength": 1
          },
          "no_go_notes": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      }
    },
    "actors": {
      "type": "array",
      "minItems": 6,
      "items": {
        "type": "object",
        "required": [
          "actor_id",
          "title",
          "actor_type",
          "current_access",
          "future_enterprise_risk",
          "trust_level",
          "approval_required"
        ],
        "properties": {
          "actor_id": {
            "type": "string",
            "minLength": 1
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "actor_type": {
            "type": "string",
            "enum": [
              "internal",
              "external",
              "future",
              "adversarial"
            ]
          },
          "current_access": {
            "type": "string",
            "minLength": 1
          },
          "future_enterprise_risk": {
            "type": "string",
            "minLength": 1
          },
          "trust_level": {
            "type": "string",
            "enum": [
              "trusted",
              "limited",
              "untrusted",
              "future"
            ]
          },
          "approval_required": {
            "type": "boolean"
          }
        },
        "additionalProperties": false
      }
    },
    "trust_boundaries": {
      "type": "array",
      "minItems": 4,
      "items": {
        "type": "object",
        "required": [
          "boundary_id",
          "title",
          "boundary_type",
          "current_state",
          "future_state",
          "crosses_network",
          "requires_future_adr",
          "no_go_gate"
        ],
        "properties": {
          "boundary_id": {
            "type": "string",
            "minLength": 1
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "boundary_type": {
            "type": "string",
            "enum": [
              "current",
              "future",
              "prohibited"
            ]
          },
          "current_state": {
            "type": "string",
            "minLength": 1
          },
          "future_state": {
            "type": "string",
            "minLength": 1
          },
          "crosses_network": {
            "type": "boolean"
          },
          "requires_future_adr": {
            "type": "boolean"
          },
          "no_go_gate": {
            "type": "boolean"
          }
        },
        "additionalProperties": false
      }
    },
    "data_flows": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "object",
        "required": [
          "flow_id",
          "title",
          "source",
          "destination",
          "data_classes",
          "current_status",
          "future_enterprise_status",
          "network_used"
        ],
        "properties": {
          "flow_id": {
            "type": "string",
            "minLength": 1
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "source": {
            "type": "string",
            "minLength": 1
          },
          "destination": {
            "type": "string",
            "minLength": 1
          },
          "data_classes": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "current_status": {
            "type": "string",
            "minLength": 1
          },
          "future_enterprise_status": {
            "type": "string",
            "minLength": 1
          },
          "network_used": {
            "type": "boolean",
            "const": false
          }
        },
        "additionalProperties": false
      }
    },
    "no_go_gates": {
      "type": "object",
      "required": [
        "enterprise_deployment_enabled",
        "production_multiuser_enabled",
        "control_plane_enabled",
        "remote_execution_enabled",
        "secure_transport_implemented",
        "compliance_certification_claim",
        "secrets_introduced",
        "network_dependency_introduced"
      ],
      "properties": {
        "enterprise_deployment_enabled": {
          "type": "boolean",
          "const": false
        },
        "production_multiuser_enabled": {
          "type": "boolean",
          "const": false
        },
        "control_plane_enabled": {
          "type": "boolean",
          "const": false
        },
        "remote_execution_enabled": {
          "type": "boolean",
          "const": false
        },
        "secure_transport_implemented": {
          "type": "boolean",
          "const": false
        },
        "compliance_certification_claim": {
          "type": "boolean",
          "const": false
        },
        "secrets_introduced": {
          "type": "boolean",
          "const": false
        },
        "network_dependency_introduced": {
          "type": "boolean",
          "const": false
        }
      },
      "additionalProperties": false
    },
    "safety": {
      "type": "object",
      "required": [
        "local_first",
        "dry_run",
        "network_used",
        "external_api_used",
        "mutations_performed",
        "source_mutations_performed",
        "remote_execution_enabled",
        "connector_write_enabled",
        "plugin_execution_enabled",
        "secrets_read"
      ],
      "properties": {
        "local_first": {
          "type": "boolean",
          "const": true
        },
        "dry_run": {
          "type": "boolean",
          "const": true
        },
        "network_used": {
          "type": "boolean",
          "const": false
        },
        "external_api_used": {
          "type": "boolean",
          "const": false
        },
        "mutations_performed": {
          "type": "boolean",
          "const": false
        },
        "source_mutations_performed": {
          "type": "boolean",
          "const": false
        },
        "remote_execution_enabled": {
          "type": "boolean",
          "const": false
        },
        "connector_write_enabled": {
          "type": "boolean",
          "const": false
        },
        "plugin_execution_enabled": {
          "type": "boolean",
          "const": false
        },
        "secrets_read": {
          "type": "boolean",
          "const": false
        }
      },
      "additionalProperties": false
    },
    "threat_catalog_summary": {
      "type": "object",
      "required": [
        "created_by",
        "methodologies",
        "boundaries_total",
        "threats_total",
        "critical_threats_total",
        "current_threats_total",
        "future_threats_total",
        "all_boundaries_have_threats",
        "critical_threats_have_controls",
        "network_used",
        "external_api_used",
        "enterprise_deployment_enabled",
        "remote_execution_enabled"
      ],
      "properties": {
        "created_by": {
          "type": "string",
          "const": "POST-H-022-B"
        },
        "methodologies": {
          "type": "array",
          "minItems": 2,
          "items": {
            "type": "string",
            "enum": [
              "STRIDE",
              "LINDDUN"
            ]
          }
        },
        "boundaries_total": {
          "type": "integer",
          "minimum": 1
        },
        "threats_total": {
          "type": "integer",
          "minimum": 1
        },
        "critical_threats_total": {
          "type": "integer",
          "minimum": 1
        },
        "current_threats_total": {
          "type": "integer",
          "minimum": 1
        },
        "future_threats_total": {
          "type": "integer",
          "minimum": 1
        },
        "all_boundaries_have_threats": {
          "type": "boolean",
          "const": true
        },
        "critical_threats_have_controls": {
          "type": "boolean",
          "const": true
        },
        "network_used": {
          "type": "boolean",
          "const": false
        },
        "external_api_used": {
          "type": "boolean",
          "const": false
        },
        "enterprise_deployment_enabled": {
          "type": "boolean",
          "const": false
        },
        "remote_execution_enabled": {
          "type": "boolean",
          "const": false
        }
      },
      "additionalProperties": false
    },
    "threat_catalog": {
      "type": "array",
      "minItems": 10,
      "items": {
        "type": "object",
        "required": [
          "threat_id",
          "title",
          "boundary_id",
          "stride_categories",
          "linddun_categories",
          "risk_timing",
          "severity",
          "affected_assets",
          "primary_actors",
          "scenario",
          "required_control_ids",
          "residual_risk_ids",
          "current_mitigation_status",
          "introduced_by"
        ],
        "properties": {
          "threat_id": {
            "type": "string",
            "pattern": "^ENT-T[0-9]{3}$"
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "boundary_id": {
            "type": "string",
            "minLength": 1
          },
          "stride_categories": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "enum": [
                "spoofing",
                "tampering",
                "repudiation",
                "information_disclosure",
                "denial_of_service",
                "elevation_of_privilege"
              ]
            }
          },
          "linddun_categories": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "enum": [
                "linkability",
                "identifiability",
                "non_repudiation",
                "detectability",
                "disclosure_of_information",
                "unawareness",
                "non_compliance"
              ]
            }
          },
          "risk_timing": {
            "type": "string",
            "enum": [
              "current",
              "future"
            ]
          },
          "severity": {
            "type": "string",
            "enum": [
              "low",
              "medium",
              "high",
              "critical"
            ]
          },
          "affected_assets": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "primary_actors": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "scenario": {
            "type": "string",
            "minLength": 1
          },
          "required_control_ids": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "pattern": "^ENT-C[0-9]{3}$"
            }
          },
          "residual_risk_ids": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "pattern": "^ENT-RR[0-9]{3}$"
            }
          },
          "current_mitigation_status": {
            "type": "string",
            "enum": [
              "implemented-design-only",
              "partial-local-control",
              "required-not-implemented",
              "blocked-by-no-go"
            ]
          },
          "introduced_by": {
            "type": "string",
            "const": "POST-H-022-B"
          }
        },
        "additionalProperties": false
      }
    },
    "required_controls": {
      "type": "array",
      "minItems": 8,
      "items": {
        "type": "object",
        "required": [
          "control_id",
          "title",
          "control_type",
          "boundary_ids",
          "mitigates_threat_ids",
          "required_before",
          "status",
          "evidence_required",
          "blocks_if_missing",
          "introduced_by"
        ],
        "properties": {
          "control_id": {
            "type": "string",
            "pattern": "^ENT-C[0-9]{3}$"
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "control_type": {
            "type": "string",
            "enum": [
              "identity",
              "rbac",
              "approval",
              "audit",
              "secrets",
              "transport",
              "isolation",
              "retention",
              "rate_limit",
              "quality_gate",
              "compliance_review"
            ]
          },
          "boundary_ids": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "mitigates_threat_ids": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "pattern": "^ENT-T[0-9]{3}$"
            }
          },
          "required_before": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "enum": [
                "enterprise_deployment",
                "production_multiuser",
                "control_plane",
                "remote_runner",
                "secure_transport",
                "compliance_claim"
              ]
            }
          },
          "status": {
            "type": "string",
            "enum": [
              "implemented-design-only",
              "partial-local-control",
              "required-not-implemented"
            ]
          },
          "evidence_required": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "blocks_if_missing": {
            "type": "boolean"
          },
          "introduced_by": {
            "type": "string",
            "const": "POST-H-022-B"
          }
        },
        "additionalProperties": false
      }
    },
    "residual_risks": {
      "type": "array",
      "minItems": 6,
      "items": {
        "type": "object",
        "required": [
          "risk_id",
          "title",
          "related_threat_ids",
          "severity",
          "status",
          "rationale",
          "future_decision_required",
          "no_go_until",
          "introduced_by"
        ],
        "properties": {
          "risk_id": {
            "type": "string",
            "pattern": "^ENT-RR[0-9]{3}$"
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "related_threat_ids": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "pattern": "^ENT-T[0-9]{3}$"
            }
          },
          "severity": {
            "type": "string",
            "enum": [
              "low",
              "medium",
              "high",
              "critical"
            ]
          },
          "status": {
            "type": "string",
            "enum": [
              "accepted-design-only",
              "requires-future-control",
              "blocked"
            ]
          },
          "rationale": {
            "type": "string",
            "minLength": 1
          },
          "future_decision_required": {
            "type": "string",
            "minLength": 1
          },
          "no_go_until": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "enum": [
                "enterprise_deployment",
                "production_multiuser",
                "control_plane",
                "remote_runner",
                "secure_transport",
                "compliance_claim"
              ]
            }
          },
          "introduced_by": {
            "type": "string",
            "const": "POST-H-022-B"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": true,
  "x-devpilot-schema-id": "SCHEMA-DEVPL-ENTERPRISE-THREAT-MODEL-V1",
  "x-devpilot-sprint": "POST-H-022-A",
  "x-devpilot-status": "registered",
  "x-devpilot-preliminary": true,
  "x-devpilot-validation-enabled-sprint": "POST-H-022-B",
  "x-devpilot-note": "POST-H-022-B extends the design-only enterprise threat model with STRIDE/LINDDUN threat catalog, required controls and residual risk register. Runtime validators, control matrix and quality gate integration remain future POST-H-022-C/D work."
}
