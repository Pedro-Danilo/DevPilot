{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://devpilot.local/schemas/SCHEMA-DEVPL-COMPLIANCE-EVIDENCE-MAPPING-V1",
  "x-devpilot-schema-id": "SCHEMA-DEVPL-COMPLIANCE-EVIDENCE-MAPPING-V1",
  "title": "DevPilot Compliance Evidence Mapping v1",
  "version": "1.0.0",
  "contract": "ComplianceEvidenceMapping",
  "description": "Schema for local evidence mappings that support non-certifying compliance control mappings.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "schema_id",
    "created_by",
    "updated_at",
    "pack_id",
    "status",
    "certification_claimed",
    "legal_advice_claimed",
    "disclaimer",
    "evidence"
  ],
  "properties": {
    "schema_version": {"const": "1.0"},
    "schema_id": {"const": "SCHEMA-DEVPL-COMPLIANCE-EVIDENCE-MAPPING-V1"},
    "created_by": {"const": "POST-H-020-A"},
    "updated_at": {"type": "string", "minLength": 1},
    "pack_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]*$"},
    "status": {"enum": ["draft", "implemented-initial", "approved"]},
    "certification_claimed": {"const": false},
    "legal_advice_claimed": {"const": false},
    "disclaimer": {"type": "string", "minLength": 40},
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "evidence_id",
          "control_ids",
          "evidence_type",
          "retention_class",
          "expected_values"
        ],
        "properties": {
          "evidence_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]*$"},
          "control_ids": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string", "pattern": "^[A-Z0-9][A-Z0-9._-]*$"},
            "uniqueItems": true
          },
          "evidence_type": {
            "enum": [
              "command-output",
              "schema-validation",
              "quality-gate",
              "test-contract",
              "documentation",
              "audit-report",
              "manifest",
              "gap-justification"
            ]
          },
          "source_command": {"type": "string", "minLength": 1},
          "source_paths": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string", "minLength": 1},
            "uniqueItems": true
          },
          "justification": {"type": "string", "minLength": 1},
          "required_fields": {
            "type": "array",
            "items": {"type": "string", "minLength": 1},
            "uniqueItems": true
          },
          "expected_values": {"type": "object"},
          "retention_class": {
            "enum": [
              "release-evidence",
              "audit-evidence",
              "runtime-evidence",
              "documentation-evidence",
              "gap-evidence"
            ]
          },
          "notes": {"type": "array", "items": {"type": "string"}}
        },
        "anyOf": [
          {"required": ["source_command"]},
          {"required": ["source_paths"]},
          {"required": ["justification"]}
        ]
      }
    },
    "safety": {
      "type": "object",
      "additionalProperties": false,
      "required": ["local_first", "network_used", "external_api_used", "mutations_performed"],
      "properties": {
        "local_first": {"const": true},
        "network_used": {"const": false},
        "external_api_used": {"const": false},
        "mutations_performed": {"const": false}
      }
    }
  }
}
