{
  "id": "security.agent",
  "version": "1.0.0",
  "status": "approved",
  "owner": "Ordóñez",
  "task": "security_agent",
  "agent_id": "security.agent",
  "description": "Prompt gobernado para SecurityAgent en modo monoagente read-only.",
  "input_variables": [
    {
      "name": "security_goal",
      "description": "Input redacted security_goal para security.agent.",
      "required": true,
      "max_length": 2000
    },
    {
      "name": "security_signals",
      "description": "Input redacted security_signals para security.agent.",
      "required": true,
      "max_length": 12000
    }
  ],
  "template": "Actúa como SecurityAgent de DevPilot en modo monoagente, read-only, dry-run y local-first. Objetivo: {{ security_goal }}. Señales redacted de threat/privacy/policy/secret scan: {{ security_signals }}. Devuelve hallazgos y mitigaciones de seguridad priorizadas. No reveles secretos, no crees aprobaciones, no ejecutes comandos, no modifiques políticas y no uses APIs externas.",
  "safety": {
    "redaction_required": true,
    "prompt_injection_scan_required": true,
    "secret_scan_required": true,
    "store_raw_prompt": false,
    "store_raw_completion": false,
    "allowed_tools": [
      "artifact.read",
      "traceability.coverage",
      "architecture.drift",
      "policy.simulate",
      "secret.scan",
      "report.write"
    ],
    "forbidden_patterns": [
      "raw_secret",
      "external_api",
      "multiagent",
      "handoff",
      "write_file",
      "delete_file",
      "execute_without_approval"
    ]
  },
  "usage": {
    "providers": [
      "mock",
      "ollama",
      "lmstudio"
    ],
    "default_provider": "mock",
    "fallback_provider": "mock",
    "max_tokens_estimated": 3000
  },
  "metadata": {
    "sprint": "FUNC-SPRINT-55",
    "preliminary": true,
    "notes": "Primera versión gobernada para security.agent; produce recomendaciones de revisión, no cambios."
  }
}
