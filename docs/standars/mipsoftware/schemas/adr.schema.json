{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mipsoftware.local/schemas/adr.schema.json",
  "title": "MIPSoftware ADR Schema",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "id",
    "title",
    "owner",
    "status",
    "version",
    "context",
    "decision",
    "consequences"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "reviewed",
        "approved",
        "deprecated"
      ]
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "updated": {
      "type": "string",
      "minLength": 1
    },
    "context": {
      "type": "string",
      "minLength": 10
    },
    "decision": {
      "type": "string",
      "minLength": 10
    },
    "consequences": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "alternatives": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}