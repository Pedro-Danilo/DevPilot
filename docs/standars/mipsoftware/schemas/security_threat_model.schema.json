{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mipsoftware.local/schemas/security_threat_model.schema.json",
  "title": "MIPSoftware Security Threat Model Schema",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "id",
    "title",
    "owner",
    "status",
    "version",
    "assets",
    "threats",
    "controls",
    "risk_rating"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "reviewed",
        "approved",
        "deprecated"
      ]
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "updated": {
      "type": "string",
      "minLength": 1
    },
    "assets": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "threats": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "controls": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "risk_rating": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high",
        "critical"
      ]
    },
    "residual_risk": {
      "type": "string"
    }
  }
}