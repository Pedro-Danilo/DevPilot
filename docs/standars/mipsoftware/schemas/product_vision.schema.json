{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mipsoftware.local/schemas/product_vision.schema.json",
  "title": "MIPSoftware Product Vision Schema",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "id",
    "title",
    "owner",
    "status",
    "version",
    "problem_statement",
    "target_users",
    "value_proposition",
    "success_metrics"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "reviewed",
        "approved",
        "deprecated"
      ]
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "updated": {
      "type": "string",
      "minLength": 1
    },
    "problem_statement": {
      "type": "string",
      "minLength": 10
    },
    "target_users": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "value_proposition": {
      "type": "string",
      "minLength": 10
    },
    "success_metrics": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "miasi_applicability": {
      "type": "string"
    }
  }
}