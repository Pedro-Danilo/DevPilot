{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MIASI Eval Card",
  "type": "object",
  "required": [
    "eval_id",
    "target_agent",
    "datasets",
    "metrics",
    "quality_gates",
    "pass_thresholds"
  ],
  "properties": {
    "eval_id": {
      "type": "string"
    },
    "target_agent": {
      "type": "string"
    },
    "datasets": {
      "type": "array"
    },
    "metrics": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "quality_gates": {
      "type": "array"
    },
    "pass_thresholds": {
      "type": "object"
    }
  },
  "additionalProperties": true
}