{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MIASI Policy Card",
  "type": "object",
  "required": [
    "policy_id",
    "scope",
    "rules",
    "default_decision",
    "approval_required_for"
  ],
  "properties": {
    "policy_id": {
      "type": "string"
    },
    "scope": {
      "type": "string"
    },
    "rules": {
      "type": "array"
    },
    "default_decision": {
      "type": "string",
      "enum": [
        "allow",
        "block",
        "require_approval"
      ]
    },
    "approval_required_for": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": true
}