  "components": {
    "schemas": {
      "Finding": {
        "type": "object",
        "required": [
          "id",
          "message",
          "severity"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "severity": {
            "type": "string",
            "enum": [
              "info",
              "warning",
              "fail",
              "block",
              "error"
            ]
          },
          "path": {
            "type": "string"
          },
          "metadata": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "additionalProperties": true
      },
      "ApplicationRequest": {
        "type": "object",
        "required": [
          "operation",
          "payload",
          "client",
          "dry_run"
        ],
        "properties": {
          "operation": {
            "type": "string"
          },
          "payload": {
            "type": "object",
            "additionalProperties": true
          },
          "client": {
            "type": "string",
            "default": "api-local"
          },
          "dry_run": {
            "type": "boolean",
            "default": true
          }
        },
        "additionalProperties": true
      },
      "ApplicationResponse": {
        "type": "object",
        "required": [
          "contract",
          "schema_version",
          "operation",
          "ok",
          "exit_code",
          "message",
          "data",
          "findings",
          "generated_at"
        ],
        "properties": {
          "contract": {
            "type": "string",
            "const": "DevPilotApplicationResponse"
          },
          "schema_version": {
            "type": "string"
          },
          "operation": {
            "type": "string"
          },
          "ok": {
            "type": "boolean"
          },
          "exit_code": {
            "type": "integer",
            "enum": [
              0,
              1,
              2,
              3
            ]
          },
          "message": {
            "type": "string"
          },
          "data": {
            "type": "object",
            "additionalProperties": true
          },
          "findings": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Finding"
            }
          },
          "generated_at": {
            "type": "string"
          }
        },
        "additionalProperties": true
      },
      "ErrorApplicationResponse": {
        "allOf": [
          {
            "$ref": "#/components/schemas/ApplicationResponse"
          }
        ],
        "description": "Error envelope preserving ApplicationResponse semantics. Non-2xx responses must still carry operation, exit_code and findings."
      }
    },
    "securitySchemes": {
      "LocalTokenAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-DevPilot-Local-Token",
        "description": "Planned for FUNC-SPRINT-68. Not enforced by Sprint 66 because no HTTP server exists."
      }
    }
  }
}
