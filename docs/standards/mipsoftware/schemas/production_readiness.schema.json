{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mipsoftware.local/schemas/production_readiness.schema.json",
  "title": "MIPSoftware Production Readiness Schema",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "id",
    "title",
    "owner",
    "status",
    "version",
    "result",
    "checks",
    "blockers"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "reviewed",
        "approved",
        "deprecated"
      ]
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "updated": {
      "type": "string",
      "minLength": 1
    },
    "result": {
      "type": "string",
      "enum": [
        "PASS",
        "FAIL",
        "BLOCK"
      ]
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object"
      },
      "minItems": 1
    },
    "blockers": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "miasi_required": {
      "type": "boolean"
    }
  }
}