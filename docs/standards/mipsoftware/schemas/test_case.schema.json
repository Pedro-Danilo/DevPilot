{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mipsoftware.local/schemas/test_case.schema.json",
  "title": "MIPSoftware Test Case Schema",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "id",
    "title",
    "owner",
    "status",
    "version",
    "linked_requirement",
    "preconditions",
    "steps",
    "expected_result",
    "test_type"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "reviewed",
        "approved",
        "deprecated"
      ]
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "updated": {
      "type": "string",
      "minLength": 1
    },
    "linked_requirement": {
      "type": "string"
    },
    "preconditions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "steps": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "expected_result": {
      "type": "string",
      "minLength": 1
    },
    "test_type": {
      "type": "string",
      "enum": [
        "unit",
        "integration",
        "contract",
        "e2e",
        "regression",
        "security",
        "performance",
        "accessibility",
        "data",
        "agentic"
      ]
    }
  }
}