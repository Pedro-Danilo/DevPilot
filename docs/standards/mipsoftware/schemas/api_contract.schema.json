{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mipsoftware.local/schemas/api_contract.schema.json",
  "title": "MIPSoftware API Contract Schema",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "id",
    "title",
    "owner",
    "status",
    "version",
    "api_name",
    "api_version",
    "endpoints",
    "auth",
    "errors"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "reviewed",
        "approved",
        "deprecated"
      ]
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "updated": {
      "type": "string",
      "minLength": 1
    },
    "api_name": {
      "type": "string"
    },
    "api_version": {
      "type": "string"
    },
    "endpoints": {
      "type": "array",
      "items": {
        "type": "object"
      },
      "minItems": 1
    },
    "auth": {
      "type": "string"
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    }
  }
}